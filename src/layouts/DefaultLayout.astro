---
import "../styles/global.css"
import Navbar from "@/components/Navbar"
import Sidebar from "@/components/Sidebar"
import Footer from "@/components/Footer.astro"
import { websiteSchema, organizationSchema, siteUrl } from "@/lib/seo"
import type { Level } from "@/lib/kanji"

export interface Props {
  title?: string
  description?: string
  noIndex?: boolean
  level?: Level
  ogImage?: string
}

const { title, description, noIndex, level, ogImage } = Astro.props
const prefix = level ? `/${level}` : ""
const canonical = Astro.url.pathname.endsWith("/") ? Astro.url.pathname : `${Astro.url.pathname}/`
const finalTitle = title || "KanjiTest.Online"
const finalDesc = description || "Free JLPT N5, N4, N3, N2, and N1 kanji study with flashcards, vocabulary, and practice tests."
const image = ogImage || "/icon.svg"
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{finalTitle}</title>
    <meta name="description" content={finalDesc} />
    {noIndex ? (
      <meta name="robots" content="noindex" />
    ) : (
      <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    )}
    <link rel="canonical" href={siteUrl(canonical)} />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="apple-touch-icon" href="/icon.svg" />
    <meta name="theme-color" content="#000000" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl(canonical)} />
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDesc} />
    <meta property="og:image" content={siteUrl(image)} />
    <meta property="og:site_name" content="KanjiTest.Online" />
    <meta property="og:locale" content="ja_JP" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={finalTitle} />
    <meta name="twitter:description" content={finalDesc} />
    <meta name="twitter:image" content={siteUrl(image)} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema())}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(organizationSchema())}
    />
  </head>
  <body class="font-sans antialiased min-h-dvh flex flex-col overflow-x-hidden">
    <Navbar client:load />
    <main class="flex-1">
      {level ? (
        <div class="max-w-6xl mx-auto">
          <div class="lg:hidden overflow-x-auto px-4 py-2 sm:py-3 scrollbar-none">
            <div class="flex gap-1.5 sm:gap-2 pb-0.5">
              <a href={`${prefix}/study/`} class="shrink-0 border border-ink/20 rounded-lg h-9 sm:h-11 px-2.5 sm:px-4 text-[11px] sm:text-sm text-ink/70 hover:border-ink/40 transition-all bg-white flex items-center">Study</a>
              <a href={`${prefix}/flashcards/`} class="shrink-0 border border-ink/20 rounded-lg h-9 sm:h-11 px-2.5 sm:px-4 text-[11px] sm:text-sm text-ink/70 hover:border-ink/40 transition-all bg-white flex items-center">Flashcards</a>
              <a href={`${prefix}/vocabulary/`} class="shrink-0 border border-ink/20 rounded-lg h-9 sm:h-11 px-2.5 sm:px-4 text-[11px] sm:text-sm text-ink/70 hover:border-ink/40 transition-all bg-white flex items-center">Vocab</a>
              <a href={`${prefix}/sets/`} class="shrink-0 border border-ink/20 rounded-lg h-9 sm:h-11 px-2.5 sm:px-4 text-[11px] sm:text-sm text-ink/70 hover:border-ink/40 transition-all bg-white flex items-center">Test</a>
              <a href={`${prefix}/`} class="shrink-0 border border-ink/20 rounded-lg h-9 sm:h-11 px-2.5 sm:px-4 text-[11px] sm:text-sm text-ink/70 hover:border-ink/40 transition-all bg-white flex items-center">Hub</a>
            </div>
          </div>

          <div class="flex">
            <aside class="hidden lg:block w-56 shrink-0">
              <div class="sticky top-20">
                <Sidebar level={level} client:load />
              </div>
            </aside>

            <div class="flex-1 min-w-0">
              <slot />
            </div>
          </div>
        </div>
      ) : (
        <slot />
      )}
    </main>
    <Footer />
  </body>
</html>