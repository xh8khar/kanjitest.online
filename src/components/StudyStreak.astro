---
export interface Props {
  showTitle?: boolean
  compact?: boolean
}

const { showTitle = true, compact = false } = Astro.props
---

<div class:list={["study-streak", { compact }]}>
  {showTitle && (
    <div class="flex items-center gap-2 mb-3">
      <span class="text-lg">🔥</span>
      <span class="text-xs font-bold uppercase tracking-widest text-ink/40">Study Streak</span>
    </div>
  )}

  <div id="ss-display" class="flex items-baseline gap-2">
    <span id="ss-count" class="text-3xl sm:text-4xl font-black text-ink">0</span>
    <span id="ss-unit" class="text-sm text-ink/50 hidden">day streak</span>
    <span id="ss-empty" class="text-sm text-ink/50">Start your streak!</span>
  </div>

  <div id="ss-week" class="flex gap-1 mt-3">
    {Array.from({ length: 7 }, (_, i) => (
      <div class="ss-day" data-day={i} />
    ))}
  </div>

  <button id="ss-btn" class="btn btn-accent h-9 px-4 text-xs mt-3">
    ✓ Log today's study
  </button>

  <p id="ss-msg" class="text-[11px] text-ink/45 mt-2" hidden></p>
</div>

<script>
  const KEY = "kanjitest_streak"

  interface StreakData {
    dates: string[]
    currentStreak: number
  }

  function load(): StreakData {
    try {
      const raw = localStorage.getItem(KEY)
      if (raw) return JSON.parse(raw)
    } catch {}
    return { dates: [], currentStreak: 0 }
  }

  function save(d: StreakData) {
    localStorage.setItem(KEY, JSON.stringify(d))
  }

  function todayKey(): string {
    return new Date().toISOString().slice(0, 10)
  }

  function calcStreak(dates: string[]): number {
    let s = 0
    const today = new Date()
    for (let i = 0; i < 365; i++) {
      const d = new Date(today)
      d.setDate(d.getDate() - i)
      const k = d.toISOString().slice(0, 10)
      if (dates.includes(k)) s++
      else break
    }
    return s
  }

  function getLast7Days(): string[] {
    const days: string[] = []
    for (let i = 6; i >= 0; i--) {
      const d = new Date()
      d.setDate(d.getDate() - i)
      days.push(d.toISOString().slice(0, 10))
    }
    return days
  }

  const data = load()
  const countEl = document.getElementById("ss-count")!
  const unitEl = document.getElementById("ss-unit")!
  const emptyEl = document.getElementById("ss-empty")!
  const weekEl = document.getElementById("ss-week")!
  const btnEl = document.getElementById("ss-btn")!
  const msgEl = document.getElementById("ss-msg")!

  // Auto-mark today on page load (passive tracking)
  const today = todayKey()
  if (!data.dates.includes(today)) {
    data.dates.push(today)
    data.currentStreak = calcStreak(data.dates)
    save(data)
  }

  function render() {
    data.currentStreak = calcStreak(data.dates)
    countEl.textContent = String(data.currentStreak)

    if (data.currentStreak > 0) {
      countEl.hidden = false
      unitEl.hidden = false
      unitEl.textContent = data.currentStreak === 1 ? "day streak" : "day streak"
      emptyEl.hidden = true
    } else {
      countEl.hidden = true
      unitEl.hidden = true
      emptyEl.hidden = false
    }

    // Render 7-day bar
    const weekDays = getLast7Days()
    const dayEls = weekEl.querySelectorAll<HTMLElement>(".ss-day")
    dayEls.forEach((el, i) => {
      const dateStr = weekDays[i]
      const dayNum = new Date(dateStr).getDate()
      el.textContent = String(dayNum)
      el.className = "ss-day " + (data.dates.includes(dateStr) ? "on" : "")
    })

    msgEl.hidden = false
    if (data.dates.includes(today)) {
      btnEl.disabled = true
      btnEl.textContent = "✓ Done for today"
      btnEl.classList.remove("btn-accent")
      btnEl.classList.add("btn-ghost")
      msgEl.textContent = "Today is logged! 🎉"
    } else {
      btnEl.disabled = false
      btnEl.textContent = "✓ Log today's study"
      btnEl.classList.add("btn-accent")
      btnEl.classList.remove("btn-ghost")
      msgEl.textContent = ""
    }
  }

  btnEl.addEventListener("click", () => {
    if (!data.dates.includes(today)) {
      data.dates.push(today)
      data.currentStreak = calcStreak(data.dates)
      save(data)
      render()
    }
  })

  render()
</script>

<style>
  .study-streak {
    background: var(--card-bg, #fff);
    border: 1px solid color-mix(in srgb, var(--color-ink) 10%, transparent);
    border-radius: 1rem;
    padding: 1.25rem;
  }
  .study-streak.compact {
    padding: 1rem;
  }
  .ss-day {
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.625rem;
    font-weight: 700;
    background: color-mix(in srgb, var(--color-ink) 5%, transparent);
    color: color-mix(in srgb, var(--color-ink) 35%, transparent);
  }
  .ss-day.on {
    background: var(--color-vermilion);
    color: #fff;
  }
</style>
