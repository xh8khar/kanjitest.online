---
import { getAll } from "@/lib/kanji"
import type { Level } from "@/lib/kanji"
import { levelMeta, SETS_PER_LEVEL } from "@/lib/levels"
import { getCollection } from "astro:content"

export interface Props {
  level: Level
}

const { level } = Astro.props
const meta = levelMeta(level)
const all = getAll(level)
const prefix = `/${level}`
const path = decodeURIComponent(Astro.url.pathname)

const blogPosts = (await getCollection("blog"))
  .filter((p) => !p.data.draft && p.data.tags.includes(meta.label))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 2)

const isActive = (href: string) => path.startsWith(href)

// Show a window of kanji around the current one so N1's 2200+ characters
// don't inflate every page; the study index has the full grid.
const WINDOW = 48
const currentIdx = all.findIndex((k) => path === `${prefix}/study/${k.kanji}/` || path === `${prefix}/flashcards/${k.kanji}/`)
const start = currentIdx === -1 ? 0 : Math.max(0, Math.min(currentIdx - Math.floor(WINDOW / 2), all.length - WINDOW))
const windowed = all.slice(start, start + WINDOW)

const tools = [
  { href: `${prefix}/study/`, label: "Study", icon: "📖" },
  { href: `${prefix}/flashcards/`, label: "Flashcards", icon: "🃏" },
  { href: `${prefix}/vocabulary/`, label: "Vocabulary", icon: "📝" },
  { href: `${prefix}/sets/`, label: "Tests", icon: "✍️" },
]
---

<div class="space-y-7 py-6 pr-6 max-h-[calc(100vh-5rem)] overflow-y-auto">
  <a href={`${prefix}/`} class="flex items-center gap-3 group">
    <span class={`w-10 h-10 rounded-xl bg-gradient-to-br ${meta.gradient} text-white font-black flex items-center justify-center shadow-lg ${meta.glow} transition-transform duration-300 group-hover:scale-105 group-hover:rotate-3`}>
      {meta.label}
    </span>
    <span>
      <span class="block text-sm font-bold text-ink leading-tight">JLPT {meta.label}</span>
      <span class="block text-[11px] text-ink/50">{meta.tagline}</span>
    </span>
  </a>

  <div class="space-y-1">
    {tools.map((t) => (
      <a href={t.href} class:list={["sb-tool", { on: isActive(t.href) }]}>
        <span class="text-base">{t.icon}</span>
        {t.label}
      </a>
    ))}
  </div>

  <div>
    <p class="sb-head">{currentIdx === -1 ? "Jump to kanji" : "Nearby kanji"}</p>
    <div class="grid grid-cols-6 gap-1">
      {windowed.map((k, i) => (
        <a href={`${prefix}/study/${k.kanji}/`} class:list={["sb-k", { on: start + i === currentIdx }]}>{k.kanji}</a>
      ))}
    </div>
    {all.length > WINDOW && (
      <a href={`${prefix}/`} class="inline-flex items-center gap-1 mt-2.5 px-1 text-[11px] font-semibold text-ink/45 hover:text-vermilion transition-colors">
        All {all.length} kanji →
      </a>
    )}
  </div>

  <div>
    <p class="sb-head">Test sets</p>
    <div class="grid grid-cols-5 gap-1">
      {Array.from({ length: SETS_PER_LEVEL }, (_, i) => i + 1).map((n) => (
        <a href={`${prefix}/sets/${n}/`} class:list={["sb-set", { on: isActive(`${prefix}/sets/${n}/`) }]}>{n}</a>
      ))}
    </div>
  </div>

  {blogPosts.length > 0 && (
    <div>
      <p class="sb-head">From the blog</p>
      <div class="space-y-1.5">
        {blogPosts.map((post) => (
          <a href={`/blog/${post.id}/`} class="block px-1 text-[11px] font-semibold text-ink/45 hover:text-vermilion transition-colors leading-relaxed">
            {post.data.title}
          </a>
        ))}
      </div>
      <a href="/blog/" class="inline-flex items-center gap-1 mt-2 px-1 text-[11px] font-semibold text-ink/45 hover:text-vermilion transition-colors">
        All articles →
      </a>
    </div>
  )}
</div>

<style>
  .sb-head {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: color-mix(in srgb, var(--color-ink) 40%, transparent);
    padding: 0 0.25rem;
    margin-bottom: 0.5rem;
  }
  .sb-tool {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0 0.75rem;
    height: 2.5rem;
    border-radius: 0.75rem;
    font-size: 0.875rem;
    color: color-mix(in srgb, var(--color-ink) 65%, transparent);
    transition: all 0.2s ease;
  }
  .sb-tool:hover {
    color: var(--color-ink);
    background: color-mix(in srgb, var(--color-ink) 5%, transparent);
    translate: 2px 0;
  }
  .sb-tool.on {
    background: var(--color-ink);
    color: #fff;
    font-weight: 600;
    box-shadow: 0 4px 12px -2px color-mix(in srgb, var(--color-ink) 20%, transparent);
  }
  .sb-k {
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-family: var(--font-jp);
    color: color-mix(in srgb, var(--color-ink) 60%, transparent);
    transition: all 0.2s ease;
  }
  .sb-k:hover {
    background: color-mix(in srgb, var(--color-ink) 8%, transparent);
    color: var(--color-ink);
    scale: 1.1;
  }
  .sb-k.on {
    background: var(--color-vermilion);
    color: #fff;
    scale: 1.05;
    box-shadow: 0 4px 12px -2px color-mix(in srgb, var(--color-vermilion) 30%, transparent);
  }
  .sb-set {
    height: 2rem;
    border-radius: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    color: color-mix(in srgb, var(--color-ink) 50%, transparent);
    transition: all 0.2s ease;
  }
  .sb-set:hover {
    background: color-mix(in srgb, var(--color-ink) 8%, transparent);
    color: var(--color-ink);
  }
  .sb-set.on {
    background: var(--color-ink);
    color: #fff;
    box-shadow: 0 4px 12px -2px color-mix(in srgb, var(--color-ink) 20%, transparent);
  }
</style>
