---
import { siteUrl } from "@/lib/seo"

export interface Props {
  /** Text prefilled into the share message; defaults to the page title */
  text?: string
}

const { text } = Astro.props
const canonical = (Astro.url.pathname.endsWith("/") ? Astro.url.pathname : `${Astro.url.pathname}/`)
  .split("/")
  .map(decodeURIComponent)
  .join("/")
const url = siteUrl(canonical)
const shareText = text || "Free JLPT kanji study, flashcards & tests — KanjiTest.online"
const eUrl = encodeURIComponent(url)
const eText = encodeURIComponent(shareText)
---

<div class="share-bar border-t border-ink/5">
  <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col sm:flex-row items-center justify-center gap-3">
    <span class="text-xs font-bold uppercase tracking-widest text-ink/35">Share with friends</span>
    <div class="flex items-center gap-2">
      <a
        class="share-btn share-x"
        href={`https://twitter.com/intent/tweet?text=${eText}&url=${eUrl}`}
        target="_blank" rel="noopener" aria-label="Share on X"
      >
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.9 2H22l-6.77 7.74L23.2 22h-6.23l-4.88-6.38L6.5 22H3.34l7.24-8.28L2.8 2h6.39l4.41 5.83L18.9 2zm-1.1 18.13h1.73L7.28 3.77H5.42l12.38 16.36z"/></svg>
      </a>
      <a
        class="share-btn share-fb"
        href={`https://www.facebook.com/sharer/sharer.php?u=${eUrl}`}
        target="_blank" rel="noopener" aria-label="Share on Facebook"
      >
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.09 10.13 24v-8.44H7.08v-3.49h3.04V9.41c0-3.02 1.79-4.7 4.53-4.7 1.31 0 2.68.24 2.68.24v2.97h-1.51c-1.49 0-1.95.93-1.95 1.89v2.26h3.32l-.53 3.49h-2.8V24C19.62 23.09 24 18.1 24 12.07z"/></svg>
      </a>
      <a
        class="share-btn share-wa"
        href={`https://wa.me/?text=${eText}%20${eUrl}`}
        target="_blank" rel="noopener" aria-label="Share on WhatsApp"
      >
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.47 14.38c-.3-.15-1.77-.87-2.04-.97-.28-.1-.48-.15-.68.15-.2.3-.77.97-.95 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.14-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.68-1.63-.93-2.23-.24-.59-.49-.51-.68-.52h-.58c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.5 0 1.47 1.07 2.89 1.22 3.09.15.2 2.11 3.22 5.11 4.51.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.13-.27-.2-.57-.35zM12.05 21.79h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.82 9.82 0 0 1-1.51-5.26c0-5.44 4.43-9.87 9.89-9.87a9.8 9.8 0 0 1 6.99 2.9 9.82 9.82 0 0 1 2.89 6.98c0 5.45-4.43 9.88-9.88 9.88zm8.41-18.29A11.8 11.8 0 0 0 12.05 0C5.5 0 .16 5.33.16 11.89c0 2.1.55 4.14 1.59 5.94L.06 24l6.33-1.66a11.9 11.9 0 0 0 5.66 1.44h.01c6.55 0 11.89-5.33 11.89-11.89 0-3.18-1.24-6.16-3.49-8.4z"/></svg>
      </a>
      <a
        class="share-btn share-line"
        href={`https://social-plugins.line.me/lineit/share?url=${eUrl}&text=${eText}`}
        target="_blank" rel="noopener" aria-label="Share on LINE"
      >
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.37 4.43A11.9 11.9 0 0 0 12 2C6.48 2 2 5.64 2 10.12c0 4.02 3.57 7.39 8.4 8.03.33.07.77.22.89.5.1.26.07.66.03.92l-.14.86c-.04.26-.2 1 .88.55s5.83-3.44 7.95-5.88C21.53 13.44 22 11.86 22 10.12c0-2.2-1-4.2-2.63-5.69zM8.14 12.86H6.16a.53.53 0 0 1-.52-.52V8.4c0-.29.24-.53.52-.53.29 0 .53.24.53.53v3.42h1.45c.29 0 .52.23.52.52 0 .28-.23.52-.52.52zm2.05-.52a.53.53 0 0 1-.53.52.53.53 0 0 1-.52-.52V8.4c0-.29.24-.53.52-.53.3 0 .53.24.53.53v3.94zm4.75 0a.53.53 0 0 1-.36.5.55.55 0 0 1-.17.02.52.52 0 0 1-.42-.2l-2.02-2.75v2.43a.52.52 0 1 1-1.05 0V8.4a.52.52 0 0 1 .95-.3l2.02 2.74V8.4c0-.29.24-.53.53-.53.28 0 .52.24.52.53v3.94zm3.19-2.5c.29 0 .52.24.52.53 0 .28-.23.52-.52.52h-1.46v.93h1.46c.29 0 .52.23.52.52 0 .28-.23.52-.52.52h-1.98a.53.53 0 0 1-.52-.52V8.4c0-.29.23-.53.52-.53h1.98c.29 0 .52.24.52.53 0 .29-.23.52-.52.52h-1.46v.93h1.46z"/></svg>
      </a>
      <a
        class="share-btn share-tg"
        href={`https://t.me/share/url?url=${eUrl}&text=${eText}`}
        target="_blank" rel="noopener" aria-label="Share on Telegram"
      >
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.94 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.06 0zm4.96 7.22c.1 0 .32.02.46.14a.5.5 0 0 1 .17.33c.02.1.04.32.02.5-.18 1.9-.96 6.5-1.36 8.63-.17.9-.5 1.2-.82 1.23-.7.06-1.23-.46-1.9-.9-1.06-.7-1.66-1.13-2.69-1.81-1.19-.78-.42-1.21.26-1.91.18-.18 3.25-2.98 3.31-3.23.01-.03.02-.15-.06-.21s-.18-.04-.25-.02c-.11.02-1.8 1.14-5.08 3.35-.48.33-.92.49-1.31.48-.43-.01-1.26-.24-1.87-.44-.76-.25-1.36-.38-1.3-.8.02-.22.32-.44.9-.68 3.55-1.55 5.91-2.57 7.1-3.06 3.38-1.41 4.08-1.65 4.54-1.66z"/></svg>
      </a>
      <button class="share-btn share-copy" data-share-copy data-url={url} aria-label="Copy link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.69l1.4-1.4a4.5 4.5 0 016.37 6.36l-3.18 3.18a4.5 4.5 0 01-6.37 0m-1.6-4.52l-1.4 1.4a4.5 4.5 0 106.36 6.37l3.18-3.18"/></svg>
        <span class="copy-tip">Copied!</span>
      </button>
      <button class="share-btn share-native" data-share-native data-url={url} data-text={shareText} aria-label="More sharing options" hidden>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7.22 10.9a3 3 0 100 2.2m0-2.2a3 3 0 110 2.2m0-2.2l8.56-4.26m-8.56 6.47l8.56 4.25m0-10.72a3 3 0 102.44-4.1 3 3 0 00-2.44 4.1zm0 10.72a3 3 0 102.44 4.1 3 3 0 00-2.44-4.1z"/></svg>
      </button>
    </div>
  </div>
</div>

<script>
  // Document-level delegation: works after view transitions and also serves
  // share buttons rendered by React islands (e.g. the quiz results screen).
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement
    const copyBtn = target.closest<HTMLElement>("[data-share-copy]")
    if (copyBtn) {
      navigator.clipboard?.writeText(copyBtn.dataset.url || location.href).then(() => {
        copyBtn.classList.add("copied")
        setTimeout(() => copyBtn.classList.remove("copied"), 1600)
      })
      return
    }
    const nativeBtn = target.closest<HTMLElement>("[data-share-native]")
    if (nativeBtn && navigator.share) {
      navigator
        .share({ url: nativeBtn.dataset.url || location.href, text: nativeBtn.dataset.text })
        .catch(() => {})
    }
  })

  // Reveal the native-share button only where the API exists (mostly mobile)
  document.addEventListener("astro:page-load", () => {
    if (navigator.share) {
      document.querySelectorAll("[data-share-native]").forEach((el) => el.removeAttribute("hidden"))
    }
  })
</script>
