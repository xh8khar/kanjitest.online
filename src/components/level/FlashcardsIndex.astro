---
import DefaultLayout from "@/layouts/DefaultLayout.astro"
import { getAll } from "@/lib/kanji"
import type { Level } from "@/lib/kanji"
import { levelMeta } from "@/lib/levels"
import { collectionPageSchema, breadcrumbSchema } from "@/lib/seo"
import { getCollection } from "astro:content"

const allBlogPosts = await getCollection("blog")
const blogPosts = allBlogPosts
  .filter((p) => !p.data.draft && p.data.tags.some((t) => ["flashcards", "kanji", "study-tips"].includes(t)))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3)

export interface Props {
  level: Level
}

const { level } = Astro.props
const meta = levelMeta(level)
const all = getAll(level)
const prefix = `/${level}`

const title = `JLPT ${meta.label} Kanji Flashcards Online — Flip & Memorize Free`
const description = `Free JLPT ${meta.label} kanji flashcards online. Flip through all ${all.length} cards to reveal readings and meanings. Track your progress with Know/Again.`
const pageSchema = collectionPageSchema(title, `All ${all.length} JLPT ${meta.label} kanji flashcards.`, `${prefix}/flashcards`)
const breadSchema = breadcrumbSchema([
  { name: "Home", url: "/" },
  { name: meta.label, url: `${prefix}/` },
  { name: "Flashcards", url: `${prefix}/flashcards/` },
])
---

<DefaultLayout title={title} description={description} level={level}>
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadSchema)} />
  <div class="px-4 py-6 sm:py-8">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between mb-6 animate-fade-up">
      <div class="min-w-0">
        <h1 class="text-xl sm:text-2xl font-black text-ink">JLPT {meta.label} Kanji Flashcards</h1>
        <p class="text-xs sm:text-sm text-ink/55 mt-1">{all.length.toLocaleString()} cards · {meta.tagline}</p>
      </div>
      <a href={`${prefix}/flashcards/${all[0]?.kanji}/`} class="btn btn-accent h-11 sm:h-10 px-5 text-sm shrink-0 self-start sm:self-auto">
        ▶ Start from card 1
      </a>
    </div>

    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-2 sm:gap-2.5">
      {all.map((k, i) => (
        <a
          href={`${prefix}/flashcards/${k.kanji}/`}
          class="kanji-tile group p-3 sm:p-4 reveal"
          style={`--reveal-delay: ${(i % 6) * 45}ms`}
        >
          <span class="block text-2xl sm:text-3xl font-jp font-bold text-ink leading-none transition-transform duration-300 group-hover:scale-110">{k.kanji}</span>
          <span class="block text-[10px] sm:text-[11px] text-ink/50 mt-1.5 truncate">{k.meanings[0]}</span>
        </a>
      ))}
    </div>

    {blogPosts.length > 0 && (
      <div class="mt-8">
        <h2 class="text-sm font-bold uppercase tracking-widest text-ink/40 mb-3 reveal">Flashcard tips</h2>
        <div class="grid sm:grid-cols-3 gap-3">
          {blogPosts.map((post, i) => (
            <a href={`/blog/${post.id}/`} class="card card-hover p-3.5 reveal" style={`--reveal-delay: ${i * 50}ms`}>
              <h3 class="text-[13px] font-bold text-ink group-hover:text-vermilion transition-colors line-clamp-2">{post.data.title}</h3>
              <p class="text-[11px] text-ink/50 mt-1 line-clamp-2">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</DefaultLayout>
