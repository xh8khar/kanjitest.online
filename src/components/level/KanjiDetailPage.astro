---
import DefaultLayout from "@/layouts/DefaultLayout.astro"
import { getByKanji, getPrevNext, getSetForKanji } from "@/lib/kanji"
import type { Level } from "@/lib/kanji"
import { levelMeta } from "@/lib/levels"
import { breadcrumbSchema, definedTermSchema } from "@/lib/seo"

export interface Props {
  level: Level
  kanji: string
}

const { level, kanji } = Astro.props
const meta = levelMeta(level)
const prefix = `/${level}`
const k = getByKanji(kanji, level)!

const { prev, next } = getPrevNext(k.id, level)
const setNum = getSetForKanji(k.id, level)
const ex = k.examples.slice(0, 3)

const termSchema = definedTermSchema(k.kanji, k.meanings.join(", "), k.id, meta.label)
const breadSchema = breadcrumbSchema([
  { name: "Home", url: "/" },
  { name: meta.label, url: `${prefix}/` },
  { name: "Study", url: `${prefix}/study/` },
  { name: k.kanji, url: `${prefix}/study/${k.kanji}/` },
])

const title = `${k.kanji} (${k.meanings[0]}) — JLPT ${meta.label} Kanji`
const description = `Learn the JLPT ${meta.label} kanji ${k.kanji} (${k.meanings[0]}).${ex[0] ? ` Example: ${ex[0].word} (${ex[0].reading}) — ${ex[0].english}.` : ""}`
---

<DefaultLayout title={title} description={description} level={level}>
  <script type="application/ld+json" set:html={JSON.stringify(breadSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(termSchema)} />

  <div class="px-4 py-6 sm:py-8">
    <nav class="text-[11px] sm:text-xs text-ink/45 mb-4 flex flex-wrap items-center gap-1 animate-fade-in">
      <a href="/" class="hover:text-ink transition-colors px-1 py-1.5">Home</a>
      <span>/</span>
      <a href={`${prefix}/`} class="hover:text-ink transition-colors px-1 py-1.5">{meta.label}</a>
      <span>/</span>
      <a href={`${prefix}/study/`} class="hover:text-ink transition-colors px-1 py-1.5">Study</a>
      <span>/</span>
      <span class="text-ink/70 px-1 py-1 font-jp">{k.kanji}</span>
    </nav>

    <!-- Character hero -->
    <div class="relative card overflow-hidden mb-5">
      <div class={`absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r ${meta.gradient}`} />
      <div class="absolute top-4 right-4 flex items-center gap-2">
        <span class="chip">#{k.id}</span>
        <span class={`chip ${meta.accentBgSoft} ${meta.accentText}`}>JLPT {meta.label}</span>
      </div>

      <div class="pt-10 pb-2 text-center">
          <h1 class="inline-block text-7xl sm:text-8xl font-jp font-black text-ink leading-none animate-ink-in">
            {k.kanji}
          </h1>
        {k.strokes > 0 && (
          <p class="text-xs text-ink/45 mt-3">{k.strokes} strokes</p>
        )}
      </div>

      <div class="px-4 sm:px-6 pt-2 pb-4 flex flex-wrap justify-center gap-1.5 animate-fade-up" style="animation-delay: 150ms">
        {k.meanings.map((m) => (
          <span class="chip text-sm px-3 py-1">{m}</span>
        ))}
      </div>

      <div class="px-4 sm:px-6 pb-5 grid grid-cols-2 gap-2.5 animate-fade-up" style="animation-delay: 250ms">
        {k.kun.length > 0 && (
          <div class="rounded-xl bg-ink/[0.03] border border-ink/8 px-4 py-3">
            <p class="text-[10px] font-bold uppercase tracking-widest text-ink/40 mb-1">Kun reading</p>
            <p class="text-sm sm:text-base text-ink font-medium">{k.kun.map((r) => r.replace(/\..+$/, "")).join("、")}</p>
          </div>
        )}
        {k.on.length > 0 && (
          <div class="rounded-xl bg-ink/[0.03] border border-ink/8 px-4 py-3">
            <p class="text-[10px] font-bold uppercase tracking-widest text-ink/40 mb-1">On reading</p>
            <p class="text-sm sm:text-base text-ink font-medium">{k.on.join("、")}</p>
          </div>
        )}
      </div>
    </div>

    <!-- Examples -->
    {ex.length > 0 && (
      <div class="mb-6">
        <p class="text-[11px] sm:text-xs font-bold uppercase tracking-widest text-ink/40 mb-3">Example words</p>
        <div class="space-y-2">
          {ex.map((e, i) => (
            <div class="card card-hover px-4 sm:px-5 py-3.5 sm:py-4 reveal" style={`--reveal-delay: ${i * 80}ms`}>
              <div class="flex items-baseline gap-2.5 flex-wrap">
                <p class="text-base sm:text-lg font-jp font-bold text-ink">{e.word}</p>
                <p class="text-xs sm:text-sm text-ink/60">{e.reading}</p>
                <p class="text-xs text-ink/45">· {e.english}</p>
              </div>
              {e.sentence && (
                <p class="text-[13px] sm:text-sm text-ink/75 mt-2 leading-relaxed font-jp">{e.sentence}</p>
              )}
              <p class="text-[11px] sm:text-xs text-ink/50 mt-1">{e.sentenceEnglish || e.english}</p>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Actions -->
    <div class="flex flex-wrap gap-2 mb-6">
      <a href={`${prefix}/flashcards/${k.kanji}/`} class="btn btn-primary h-11 px-5 text-xs sm:text-sm">
        🃏 Practice this card
      </a>
      <a href={`${prefix}/sets/${setNum}/`} class="btn btn-ghost h-11 px-5 text-xs sm:text-sm">
        ✍️ Test yourself (Set {setNum})
      </a>
    </div>

    <!-- Prev / Next -->
    <div class="flex gap-2">
      {prev ? (
        <a href={`${prefix}/study/${prev.kanji}/`} class="card card-hover group flex-1 h-14 flex items-center gap-2.5 px-4 text-sm text-ink/70">
          <span class="text-ink/35 transition-transform duration-300 group-hover:-translate-x-1">&larr;</span>
          <span class="font-jp text-lg font-bold text-ink">{prev.kanji}</span>
          <span class="hidden sm:inline text-[11px] text-ink/40 truncate">{prev.meanings[0]}</span>
        </a>
      ) : <div class="flex-1" />}
      {next ? (
        <a href={`${prefix}/study/${next.kanji}/`} class="card card-hover group flex-1 h-14 flex items-center justify-end gap-2.5 px-4 text-sm text-ink/70">
          <span class="hidden sm:inline text-[11px] text-ink/40 truncate">{next.meanings[0]}</span>
          <span class="font-jp text-lg font-bold text-ink">{next.kanji}</span>
          <span class="text-ink/35 transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
        </a>
      ) : <div class="flex-1" />}
    </div>
  </div>
</DefaultLayout>
