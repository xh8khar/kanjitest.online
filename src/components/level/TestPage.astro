---
import DefaultLayout from "@/layouts/DefaultLayout.astro"
import TestClient from "@/components/TestClient"
import { getSetQuestions } from "@/lib/kanji"
import type { Level } from "@/lib/kanji"
import { levelMeta, QUESTIONS_PER_SET } from "@/lib/levels"
import { breadcrumbSchema, quizSchema } from "@/lib/seo"

export interface Props {
  level: Level
  setNum: number
}

const { level, setNum } = Astro.props
const meta = levelMeta(level)
const prefix = `/${level}`

// Questions are generated at build time and serialized as island props,
// so the level's full JSON dataset never ships to the browser.
const questions = getSetQuestions(setNum, level)

const title = `Free JLPT ${meta.label} Kanji Quiz Set ${setNum} — ${QUESTIONS_PER_SET} Questions | Kanji Test Online`
const description = `Free JLPT ${meta.label} kanji practice test and mock quiz — Set ${setNum} of ${QUESTIONS_PER_SET} multiple choice questions. Test your kanji-to-reading and reading-to-kanji skills with real sentence context.`

const pageSchema = quizSchema(title, description, QUESTIONS_PER_SET, `${prefix}/sets/${setNum}/`)
const breadSchema = breadcrumbSchema([
  { name: "Home", url: "/" },
  { name: meta.label, url: `${prefix}/` },
  { name: "Tests", url: `${prefix}/sets/` },
  { name: `Set ${setNum}`, url: `${prefix}/sets/${setNum}/` },
])
---

<DefaultLayout title={title} description={description} level={level}>
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadSchema)} />
  <h1 class="sr-only">Kanji Test Online — JLPT {meta.label} Set {setNum}</h1>
  <TestClient client:load level={level} setNum={setNum} questions={questions} />
</DefaultLayout>
