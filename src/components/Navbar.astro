---
import { LEVELS, LEVEL_IDS } from "@/lib/levels"

const path = Astro.url.pathname

const SUB_LINKS = [
  { id: "study", label: "Study", icon: "📖" },
  { id: "flashcards", label: "Flashcards", icon: "🃏" },
  { id: "vocabulary", label: "Vocabulary", icon: "📝" },
  { id: "sets", label: "Tests", icon: "✍️" },
]

const isLevelActive = (id: string) => path === `/${id}/` || path.startsWith(`/${id}/`)
const isSubActive = (id: string, sub: string) => path.startsWith(`/${id}/${sub}/`)
---

<header class="sticky top-0 z-50 bg-paper/85 backdrop-blur-md border-b border-ink/10">
  <nav class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 shrink-0 group" aria-label="KanjiTest.Online home">
      <span class="hanko w-8 h-8 text-lg transition-transform duration-300 group-hover:rotate-[8deg] group-hover:scale-105">漢</span>
      <span class="text-lg font-black text-ink tracking-tight">KanjiTest<span class="text-vermilion">.online</span></span>
    </a>

    <!-- Desktop -->
    <div class="hidden md:flex items-center h-full gap-0.5">
      {LEVEL_IDS.map((id) => {
        const lv = LEVELS[id]
        const active = isLevelActive(id)
        return (
          <div class="relative h-full group">
            <a
              href={`/${id}/`}
              class={`relative h-full flex items-center px-3 text-sm font-semibold transition-colors ${
                active ? "text-ink" : "text-ink/60 hover:text-ink"
              }`}
            >
              {lv.label}
              <svg class="ml-1 w-3 h-3 opacity-50 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
              </svg>
              <span
                class={`absolute bottom-0 left-3 right-3 h-0.5 rounded-full bg-vermilion origin-left transition-transform duration-300 ${
                  active ? "scale-x-100" : "scale-x-0 group-hover:scale-x-100"
                }`}
              />
            </a>
            <div class="absolute top-full left-1/2 -translate-x-1/2 pt-1.5 opacity-0 invisible translate-y-1 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-200 ease-out">
              <div class="bg-white border border-ink/10 rounded-2xl shadow-xl shadow-ink/10 p-1.5 min-w-[168px]">
                {SUB_LINKS.map((sub) => (
                  <a
                    href={`/${id}/${sub.id}/`}
                    class={`flex items-center gap-2.5 px-3 py-2.5 text-sm rounded-xl transition-colors ${
                      isSubActive(id, sub.id)
                        ? "text-ink font-semibold bg-ink/5"
                        : "text-ink/65 hover:text-ink hover:bg-ink/5"
                    }`}
                  >
                    <span class="text-base">{sub.icon}</span>
                    {sub.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        )
      })}
    </div>

    <!-- Mobile hamburger (bars morph into an X) -->
    <button
      data-nav-toggle
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Menu"
      class="nav-burger md:hidden w-11 h-11 -mr-1 flex flex-col items-center justify-center gap-[5px]"
    >
      <span class="bar" /><span class="bar" /><span class="bar" />
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="nav-panel md:hidden border-ink/10 bg-paper/95 backdrop-blur-md">
    <div class="overflow-hidden min-h-0">
      <div class="px-3 py-3 space-y-1 max-h-[80vh] overflow-y-auto">
        {LEVEL_IDS.map((id) => {
          const lv = LEVELS[id]
          const active = isLevelActive(id)
          return (
            <div class="rounded-2xl overflow-hidden bg-white border border-ink/10">
              <button
                data-acc-toggle
                class={`acc-btn w-full flex items-center justify-between px-4 h-12 text-sm font-bold transition-colors ${
                  active ? "text-ink" : "text-ink/70"
                }`}
              >
                <span class="flex items-center gap-2.5">
                  <span class={`w-2 h-2 rounded-full ${lv.accentBg}`} />
                  JLPT {lv.label}
                  <span class="text-[10px] font-medium text-ink/40">{lv.tagline}</span>
                </span>
                <svg class="acc-chevron w-3.5 h-3.5 text-ink/40 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="acc-panel">
                <div class="overflow-hidden min-h-0">
                  <div class="grid grid-cols-2 gap-1.5 px-3 pb-3">
                    {SUB_LINKS.map((sub) => (
                      <a
                        href={`/${id}/${sub.id}/`}
                        class={`flex items-center gap-2 px-3 h-11 rounded-xl text-[13px] transition-colors ${
                          isSubActive(id, sub.id)
                            ? "bg-ink text-white font-semibold"
                            : "bg-ink/[0.04] text-ink/70 active:bg-ink/10"
                        }`}
                      >
                        <span>{sub.icon}</span>
                        {sub.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          )
        })}
      </div>
    </div>
  </div>
</header>

<style>
  /* Hamburger bars morph to an X when expanded */
  .nav-burger .bar {
    width: 20px;
    height: 2px;
    border-radius: 2px;
    background: color-mix(in srgb, var(--color-ink) 75%, transparent);
    transition: transform 0.3s var(--ease-out-expo), opacity 0.2s ease;
  }
  .nav-burger[aria-expanded="true"] .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-burger[aria-expanded="true"] .bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0.4);
  }
  .nav-burger[aria-expanded="true"] .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Slide-open panels via the grid-rows trick */
  .nav-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s var(--ease-out-expo);
    border-bottom-width: 0;
  }
  .nav-panel.menu-open {
    grid-template-rows: 1fr;
    border-bottom-width: 1px;
  }
  .acc-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s var(--ease-out-expo);
  }
  .acc-btn.acc-open + .acc-panel {
    grid-template-rows: 1fr;
  }
  .acc-btn.acc-open .acc-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  // Event delegation on document so it survives view-transition DOM swaps.
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement
    const toggle = target.closest<HTMLElement>("[data-nav-toggle]")
    if (toggle) {
      const menu = document.getElementById("mobile-menu")
      const open = menu?.classList.toggle("menu-open") ?? false
      toggle.setAttribute("aria-expanded", String(open))
      return
    }
    const acc = target.closest<HTMLElement>("[data-acc-toggle]")
    if (acc) acc.classList.toggle("acc-open")
  })
</script>
