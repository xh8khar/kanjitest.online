---
import { LEVELS, LEVEL_IDS } from "@/lib/levels"

const path = Astro.url.pathname

const LEARN_LINKS = [
  { href: "/learn/radicals/", label: "Radicals", icon: "⼀" },
  { href: "/learn/hiragana/", label: "Hiragana", icon: "あ" },
  { href: "/learn/katakana/", label: "Katakana", icon: "ア" },
]

const SUB_LINKS = [
  { id: "study", label: "Study", icon: "📖" },
  { id: "flashcards", label: "Flashcards", icon: "🃏" },
  { id: "vocabulary", label: "Vocabulary", icon: "📝" },
  { id: "sets", label: "Tests", icon: "✍️" },
]

const isLevelActive = (id: string) => path === `/${id}/` || path.startsWith(`/${id}/`)
const isSubActive = (id: string, sub: string) => path.startsWith(`/${id}/${sub}/`)
---

<header class="sticky top-0 z-50 bg-paper/85 backdrop-blur-md border-b border-ink/10">
  <nav class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 shrink-0 group" aria-label="KanjiTest.Online home">
      <svg viewBox="0 0 512 512" class="w-8 h-8 transition-transform duration-300 group-hover:rotate-[8deg] group-hover:scale-105" aria-hidden="true">
        <circle cx="256" cy="256" r="240" fill="#d9482f"/>
        <text x="256" y="256" dominant-baseline="central" text-anchor="middle" font-family="sans-serif" font-weight="900" font-size="280" fill="white">日</text>
      </svg>
      <span class="text-lg font-black text-ink tracking-tight">KanjiTest<span class="text-vermilion">.Online</span></span>
    </a>

    <!-- Desktop -->
    <div class="hidden md:flex items-center h-full gap-0.5">
      <a href="/blog/" class:list={["nav-lv", { on: path.startsWith("/blog/") }]}>
        Blog
        <span class="nav-bar" />
      </a>
      <a href="/tools/" class:list={["nav-lv", { on: path.startsWith("/tools/") }]}>
        Tools
        <span class="nav-bar" />
      </a>
      <div class="relative h-full group">
        <a href="/learn/" class:list={["nav-lv", { on: path.startsWith("/learn/") }]}>
          Learn
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
          </svg>
          <span class="nav-bar" />
        </a>
        <div class="nav-drop">
          <div class="nav-drop-in">
            {LEARN_LINKS.map((s) => (
              <a href={s.href} class:list={["nav-sub", { on: path.startsWith(s.href) }]}>
                <span class="text-base">{s.icon}</span>
                {s.label}
              </a>
            ))}
          </div>
        </div>
      </div>
      {LEVEL_IDS.map((id) => (
        <div class="relative h-full group">
          <a href={`/${id}/`} class:list={["nav-lv", { on: isLevelActive(id) }]}>
            {LEVELS[id].label}
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
            </svg>
            <span class="nav-bar" />
          </a>
          <div class="nav-drop">
            <div class="nav-drop-in">
              {SUB_LINKS.map((sub) => (
                <a href={`/${id}/${sub.id}/`} class:list={["nav-sub", { on: isSubActive(id, sub.id) }]}>
                  <span class="text-base">{sub.icon}</span>
                  {sub.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Mobile hamburger (bars morph into an X) -->
    <button
      data-nav-toggle
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Menu"
      class="nav-burger md:hidden w-11 h-11 -mr-1 flex flex-col items-center justify-center gap-[5px]"
    >
      <span class="bar" /><span class="bar" /><span class="bar" />
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="nav-panel md:hidden border-ink/10 bg-paper/95 backdrop-blur-md">
    <div class="overflow-hidden min-h-0">
      <div class="px-3 py-3 space-y-1 max-h-[80vh] overflow-y-auto">
        <a href="/blog/" class:list={["m-sub mb-1.5 flex items-center gap-2.5 px-3 py-2.5 rounded-xl w-full text-sm font-bold font-semibold tracking-tight", { on: path.startsWith("/blog/") || path === "/blog" }]}>
          <span class="text-base">✍️</span>
          Blog
        </a>
        <a href="/tools/" class:list={["m-sub mb-1.5 flex items-center gap-2.5 px-3 py-2.5 rounded-xl w-full text-sm font-bold font-semibold tracking-tight", { on: path.startsWith("/tools/") || path === "/tools" }]}>
          <span class="text-base">🔧</span>
          Tools
        </a>
        <div class="rounded-2xl overflow-hidden bg-white border border-ink/10 mb-1.5">
          <button data-acc-toggle class="acc-btn">
            <span class="flex items-center gap-2.5">
              <span class="text-base">📚</span>
              Learn
            </span>
            <svg class="acc-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="acc-panel">
            <div class="overflow-hidden min-h-0">
              <div class="grid grid-cols-2 gap-1.5 px-3 pb-3">
                {LEARN_LINKS.map((s) => (
                  <a href={s.href} class:list={["m-sub", { on: path.startsWith(s.href) }]}>
                    <span>{s.icon}</span>
                    {s.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
        {LEVEL_IDS.map((id) => {
          const lv = LEVELS[id]
          return (
            <div class="rounded-2xl overflow-hidden bg-white border border-ink/10">
              <button data-acc-toggle class:list={["acc-btn", { on: isLevelActive(id) }]}>
                <span class="flex items-center gap-2.5">
                  <span class={`w-2 h-2 rounded-full ${lv.accentBg}`} />
                  JLPT {lv.label}
                  <span class="text-[10px] font-medium text-ink/40">{lv.tagline}</span>
                </span>
                <svg class="acc-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="acc-panel">
                <div class="overflow-hidden min-h-0">
                  <div class="grid grid-cols-2 gap-1.5 px-3 pb-3">
                    {SUB_LINKS.map((sub) => (
                      <a href={`/${id}/${sub.id}/`} class:list={["m-sub", { on: isSubActive(id, sub.id) }]}>
                        <span>{sub.icon}</span>
                        {sub.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          )
        })}
      </div>
    </div>
  </div>
</header>

<style>
  /* Desktop level link */
  .nav-lv {
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;
    padding: 0 0.75rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: color-mix(in srgb, var(--color-ink) 60%, transparent);
    transition: color 0.2s ease;
  }
  .nav-lv:hover,
  .nav-lv.on {
    color: var(--color-ink);
  }
  .nav-lv svg {
    margin-left: 0.25rem;
    width: 0.75rem;
    height: 0.75rem;
    opacity: 0.5;
    transition: transform 0.3s ease;
  }
  .group:hover .nav-lv svg {
    transform: rotate(180deg);
  }
  .nav-bar {
    position: absolute;
    bottom: 0;
    left: 0.75rem;
    right: 0.75rem;
    height: 2px;
    border-radius: 9999px;
    background: var(--color-vermilion);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }
  .nav-lv.on .nav-bar,
  .group:hover .nav-bar {
    transform: scaleX(1);
  }

  /* Desktop dropdown */
  .nav-drop {
    position: absolute;
    top: 100%;
    left: 50%;
    translate: -50% 0.25rem;
    padding-top: 0.375rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, translate 0.2s ease, visibility 0.2s;
  }
  .group:hover .nav-drop {
    opacity: 1;
    visibility: visible;
    translate: -50% 0;
  }
  .nav-drop-in {
    background: #fff;
    border: 1px solid color-mix(in srgb, var(--color-ink) 10%, transparent);
    border-radius: 1rem;
    box-shadow: 0 20px 40px -12px color-mix(in srgb, var(--color-ink) 15%, transparent);
    padding: 0.375rem;
    min-width: 168px;
  }
  .nav-sub {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 0.75rem;
    font-size: 0.875rem;
    border-radius: 0.75rem;
    color: color-mix(in srgb, var(--color-ink) 65%, transparent);
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  .nav-sub:hover,
  .nav-sub.on {
    color: var(--color-ink);
    background: color-mix(in srgb, var(--color-ink) 5%, transparent);
  }
  .nav-sub.on {
    font-weight: 600;
  }

  /* Hamburger bars morph to an X when expanded */
  .nav-burger .bar {
    width: 20px;
    height: 2px;
    border-radius: 2px;
    background: color-mix(in srgb, var(--color-ink) 75%, transparent);
    transition: transform 0.3s var(--ease-out-expo), opacity 0.2s ease;
  }
  .nav-burger[aria-expanded="true"] .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-burger[aria-expanded="true"] .bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0.4);
  }
  .nav-burger[aria-expanded="true"] .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Slide-open panels via the grid-rows trick */
  .nav-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s var(--ease-out-expo);
    border-bottom-width: 0;
  }
  .nav-panel.menu-open {
    grid-template-rows: 1fr;
    border-bottom-width: 1px;
  }
  .acc-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1rem;
    height: 3rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: color-mix(in srgb, var(--color-ink) 70%, transparent);
  }
  .acc-btn.on {
    color: var(--color-ink);
  }
  .acc-chevron {
    width: 0.875rem;
    height: 0.875rem;
    color: color-mix(in srgb, var(--color-ink) 40%, transparent);
    transition: transform 0.3s ease;
  }
  .acc-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s var(--ease-out-expo);
  }
  .acc-btn.acc-open + .acc-panel {
    grid-template-rows: 1fr;
  }
  .acc-btn.acc-open .acc-chevron {
    transform: rotate(180deg);
  }
  .m-sub {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 0.75rem;
    height: 2.75rem;
    border-radius: 0.75rem;
    font-size: 13px;
    background: color-mix(in srgb, var(--color-ink) 4%, transparent);
    color: color-mix(in srgb, var(--color-ink) 70%, transparent);
  }
  .m-sub:active {
    background: color-mix(in srgb, var(--color-ink) 10%, transparent);
  }
  .m-sub.on {
    background: var(--color-ink);
    color: #fff;
    font-weight: 600;
  }
</style>

<script>
  // Event delegation on document so it survives view-transition DOM swaps.
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement
    const toggle = target.closest<HTMLElement>("[data-nav-toggle]")
    if (toggle) {
      const menu = document.getElementById("mobile-menu")
      const open = menu?.classList.toggle("menu-open") ?? false
      toggle.setAttribute("aria-expanded", String(open))
      return
    }
    const acc = target.closest<HTMLElement>("[data-acc-toggle]")
    if (acc) acc.classList.toggle("acc-open")
  })
</script>
