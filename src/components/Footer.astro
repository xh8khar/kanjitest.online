---
import { LEVELS, LEVEL_IDS } from "@/lib/levels"
import { siteUrl } from "@/lib/seo"

const SUB_LINKS = [
  { id: "study", label: "Study" },
  { id: "flashcards", label: "Flashcards" },
  { id: "vocabulary", label: "Vocabulary" },
  { id: "sets", label: "Tests" },
]
---

<footer class="relative bg-ink text-white/80 mt-auto overflow-hidden">
  <span aria-hidden="true" class="absolute -right-8 -bottom-16 text-[16rem] leading-none font-jp font-black text-white/[0.04] select-none pointer-events-none">
    漢字
  </span>

  <div class="relative max-w-6xl mx-auto px-4 py-12 sm:py-16">
    <div class="grid gap-10 md:grid-cols-[1.2fr_2fr]">
      <div>
        <a href="/" class="inline-flex items-center gap-2.5 group">
          <svg viewBox="0 0 512 512" class="w-9 h-9 transition-transform duration-300 group-hover:rotate-[8deg]" aria-hidden="true">
            <circle cx="256" cy="256" r="240" fill="#d9482f"/>
            <text x="256" y="256" dominant-baseline="central" text-anchor="middle" font-family="sans-serif" font-weight="900" font-size="280" fill="white">日</text>
          </svg>
          <span class="text-lg font-black text-white tracking-tight">KanjiTest<span class="text-vermilion">.online</span></span>
        </a>
        <p class="text-sm text-white/50 mt-3 max-w-xs leading-relaxed">
          Free JLPT kanji study, flashcards, vocabulary, and practice tests. Every level, no account, forever free.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-6">
        {LEVEL_IDS.map((id) => {
          const lv = LEVELS[id]
          return (
            <div>
              <a href={`/${id}/`} class="inline-flex items-center gap-1.5 text-sm font-bold text-white hover:text-vermilion transition-colors">
                <span class={`w-1.5 h-1.5 rounded-full ${lv.accentBg}`} />
                {lv.label}
              </a>
              <div class="flex flex-col gap-1.5 mt-2.5">
                {SUB_LINKS.map((s) => (
                  <a href={`/${id}/${s.id}/`} class="fl">{s.label}</a>
                ))}
              </div>
            </div>
          )
        })}
      </div>
    </div>

    <div class="flex flex-wrap items-center justify-between gap-x-5 gap-y-2 text-[13px] mt-10 pt-6 border-t border-white/10">
      <div class="flex gap-5">
        <a href="/blog/" class="text-white/45 hover:text-white transition-colors">Blog</a>
        <a href="/about/" class="text-white/45 hover:text-white transition-colors">About</a>
        <a href="/privacy/" class="text-white/45 hover:text-white transition-colors">Privacy</a>
        <a href="/terms/" class="text-white/45 hover:text-white transition-colors">Terms</a>
      </div>
      <span class="text-xs text-white/35">&copy; 2026 {siteUrl().replace("https://", "")} — がんばって 🌸</span>
    </div>
  </div>
</footer>

<style>
  .fl {
    font-size: 13px;
    width: fit-content;
    color: rgb(255 255 255 / 0.45);
    transition: color 0.15s ease;
  }
  .fl:hover {
    color: #fff;
  }
</style>
