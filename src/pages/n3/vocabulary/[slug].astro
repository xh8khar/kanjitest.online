---
import VocabDetailPage from "@/components/level/VocabDetailPage.astro"
import { getVocabulary } from "@/lib/kanji"

export function getStaticPaths() {
  return getVocabulary("n3").map((v) => ({ params: { slug: v.slug } }))
}

const slug = decodeURIComponent(Astro.params.slug!)
---

<VocabDetailPage level="n3" slug={slug} />
