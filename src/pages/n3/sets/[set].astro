---
import DefaultLayout from "@/layouts/DefaultLayout.astro"
import TestClient from "@/components/TestClient"

export function getStaticPaths() {
  return Array.from({ length: 20 }, (_, i) => ({ params: { set: String(i + 1) } }))
}

const level = "n3"
const { set } = Astro.params
const setNum = parseInt(set!)
const title = `Kanji Test Online – JLPT N3 Kanji Quiz Set ${setNum} (20 Questions)`
const description = `Practice JLPT N3 kanji with Set ${setNum} of 20 questions. Test your kanji-to-reading and reading-to-kanji skills.`
---

<DefaultLayout title={title} description={description} level="n3">
  <TestClient setNum={setNum} level={level} client:load />
</DefaultLayout>
