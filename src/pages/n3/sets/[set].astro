---
import TestPage from "@/components/level/TestPage.astro"
import { SETS_PER_LEVEL } from "@/lib/levels"

export function getStaticPaths() {
  return Array.from({ length: SETS_PER_LEVEL }, (_, i) => ({ params: { set: String(i + 1) } }))
}

const setNum = parseInt(Astro.params.set!, 10)
---

<TestPage level="n3" setNum={setNum} />
