---
import DefaultLayout from "@/layouts/DefaultLayout.astro"
import { getAll, getVocabulary } from "@/lib/kanji"
import { LEVELS, LEVEL_IDS, SETS_PER_LEVEL, QUESTIONS_PER_SET } from "@/lib/levels"
import { collectionPageSchema, breadcrumbSchema } from "@/lib/seo"
import { getCollection } from "astro:content"

const featuredPosts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 6)

const levels = LEVEL_IDS.map((id) => ({
  ...LEVELS[id],
  kanji: getAll(id).length,
  vocab: getVocabulary(id).length,
}))

const totalKanji = levels.reduce((s, l) => s + l.kanji, 0)
const totalVocab = levels.reduce((s, l) => s + l.vocab, 0)
const maxKanji = Math.max(...levels.map((l) => l.kanji))

const floatingKanji = [
  { char: "学", top: "12%", left: "6%", size: "text-5xl", delay: "0s", rot: "-8deg" },
  { char: "桜", top: "22%", left: "88%", size: "text-6xl", delay: "1.2s", rot: "6deg" },
  { char: "夢", top: "64%", left: "4%", size: "text-4xl", delay: "0.6s", rot: "5deg" },
  { char: "道", top: "70%", left: "92%", size: "text-5xl", delay: "1.8s", rot: "-5deg" },
  { char: "心", top: "8%", left: "70%", size: "text-4xl", delay: "2.4s", rot: "-4deg" },
  { char: "空", top: "48%", left: "82%", size: "text-4xl", delay: "0.9s", rot: "7deg" },
  { char: "力", top: "40%", left: "10%", size: "text-6xl", delay: "1.5s", rot: "4deg" },
]

const sampleKanji = [
  { char: "学", meaning: "study", level: "N5", url: "/n5/study/学/" },
  { char: "校", meaning: "school", level: "N5", url: "/n5/study/校/" },
  { char: "生", meaning: "life", level: "N5", url: "/n5/study/生/" },
  { char: "食", meaning: "eat", level: "N5", url: "/n5/study/食/" },
  { char: "時", meaning: "time", level: "N5", url: "/n5/study/時/" },
  { char: "物", meaning: "thing", level: "N4", url: "/n4/study/物/" },
  { char: "病", meaning: "sick", level: "N4", url: "/n4/study/病/" },
  { char: "美", meaning: "beauty", level: "N3", url: "/n3/study/美/" },
]

const jsonLd = collectionPageSchema(
  "Free JLPT Kanji Test Online — KanjiTest.Online",
  "Free JLPT N5, N4, N3, N2, and N1 kanji tests with answers. Study with flashcards, vocabulary, and practice quizzes.",
  "/"
)

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How many kanji are in JLPT N5?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `JLPT N5 has 79 kanji characters. These are the most fundamental Japanese characters that every beginner learns first, covering basic nouns, verbs, and adjectives.`,
      },
    },
    {
      "@type": "Question",
      name: "How many kanji are in JLPT N4?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `JLPT N4 has 168 kanji characters. These build on N5 and cover everyday kanji used in basic conversations and simple reading materials.`,
      },
    },
    {
      "@type": "Question",
      name: "How many kanji are in JLPT N3?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `JLPT N3 has 365 kanji characters. These are upper-intermediate characters that bridge daily life vocabulary and more formal written Japanese such as news articles.`,
      },
    },
    {
      "@type": "Question",
      name: "How many kanji are in JLPT N2?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `JLPT N2 has 686 kanji characters. These are advanced kanji found in newspapers, workplaces, and serious reading materials.`,
      },
    },
    {
      "@type": "Question",
      name: "How many kanji are in JLPT N1?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `JLPT N1 has 1,237 kanji characters. This covers the full sweep of literary, academic, and professional Japanese required for native-level fluency.`,
      },
    },
    {
      "@type": "Question",
      name: "What is the best JLPT kanji test online?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `KanjiTest.Online is a free JLPT kanji test platform covering all levels from N5 to N1. It offers multiple choice quizzes, flashcards, vocabulary lists, and detailed kanji study pages — all without requiring an account or payment.`,
      },
    },
    {
      "@type": "Question",
      name: "Where can I practice JLPT kanji?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `You can practice JLPT kanji for free on KanjiTest.Online. The site offers study pages with readings and examples, flip flashcards for active recall, vocabulary lists with sentences, and ${SETS_PER_LEVEL} practice test sets per level with instant feedback.`,
      },
    },
    {
      "@type": "Question",
      name: "Is JLPT N3 kanji difficult?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `JLPT N3 kanji is moderately difficult — it requires learning 365 characters beyond the 247 in N5 and N4 combined. N3 marks the transition from beginner to intermediate Japanese, introducing more abstract vocabulary and concepts. With consistent practice using flashcards and quizzes, most learners find N3 achievable within 6-12 months of study.`,
      },
    },
    {
      "@type": "Question",
      name: "How to study JLPT N2 kanji?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `To study JLPT N2 kanji effectively: (1) Review N3 kanji first to build a strong foundation. (2) Study kanji in context using example words and sentences rather than in isolation. (3) Use flashcards for spaced repetition and active recall. (4) Take practice tests to identify weak areas. KanjiTest.Online offers all these tools for free across every JLPT level.`,
      },
    },
    {
      "@type": "Question",
      name: "How to pass JLPT N1 kanji section?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `To pass the JLPT N1 kanji section: (1) Master all 1,237 N1 kanji with their multiple readings and meanings. (2) Study vocabulary in context — N1 tests kanji within compound words and sentences. (3) Practice reading authentic materials like newspaper editorials and literary texts. (4) Use mock tests to simulate exam conditions. KanjiTest.Online provides N1 flashcards, vocabulary, and practice quizzes to help you prepare.`,
      },
    },
  ],
}
---

<DefaultLayout
  title="Free JLPT Kanji Test Online — Practice Test, Quiz & Flashcards for N5 to N1"
  description="Free JLPT kanji test online and practice test with mock exams for N5 to N1. Take a JLPT kanji quiz free, study with flashcards, and prepare for the Japanese kanji test online. No account needed."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- ———————— Hero ———————— -->
  <section class="relative overflow-hidden">
    <!-- soft gradient blobs -->
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-24 -left-24 w-96 h-96 rounded-full bg-vermilion/10 blur-3xl animate-drift" />
      <div class="absolute -bottom-32 -right-16 w-[28rem] h-[28rem] rounded-full bg-sky-400/10 blur-3xl animate-drift" style="animation-delay: -7s" />
      {floatingKanji.map((f) => (
        <span
          class={`hidden sm:block absolute font-jp font-black text-ink/[0.06] select-none animate-float ${f.size}`}
          style={`top:${f.top}; left:${f.left}; animation-delay:${f.delay}; --float-rot:${f.rot}`}
        >
          {f.char}
        </span>
      ))}
    </div>

    <div class="relative max-w-5xl mx-auto px-4 pt-14 sm:pt-24 pb-16 sm:pb-24 text-center">
      <div class="inline-flex items-center gap-2 border border-ink/10 text-ink/60 text-xs sm:text-sm rounded-full px-4 py-1.5 mb-6 font-medium shadow-sm animate-fade-up" style="background:var(--card-bg,#fff)">
        <span class="relative flex w-2 h-2">
          <span class="absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75 animate-ping" />
          <span class="relative inline-flex rounded-full w-2 h-2 bg-emerald-500" />
        </span>
        {totalKanji.toLocaleString()} kanji · {totalVocab.toLocaleString()} words · free forever
      </div>

      <h1 class="text-4xl sm:text-6xl md:text-7xl font-black text-ink leading-[1.05] tracking-tight text-balance animate-fade-up" style="animation-delay: 80ms">
        Master JLPT kanji,<br />
        <span class="relative inline-block text-vermilion">
          one character
          <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 200 9" fill="none" preserveAspectRatio="none" aria-hidden="true">
            <path d="M2 7c40-5 120-5 196-3" stroke="currentColor" stroke-width="4" stroke-linecap="round" class="text-vermilion/40" />
          </svg>
        </span>{" "}at a time.
      </h1>

      <p class="text-sm sm:text-lg text-ink/60 mt-5 max-w-xl mx-auto leading-relaxed animate-fade-up" style="animation-delay: 160ms">
        Study readings and real sentences, flip flashcards, and take practice tests
        for every level from N5 to N1 — no account, no paywall.
      </p>

      <div class="flex flex-wrap justify-center gap-3 mt-8 sm:mt-10 animate-fade-up" style="animation-delay: 240ms">
        <a href="/n5/study/" class="btn btn-accent h-12 sm:h-13 px-7 sm:px-9 text-sm sm:text-base">
          Start studying
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
        <a href="#levels" class="btn btn-ghost h-12 sm:h-13 px-7 sm:px-9 text-sm sm:text-base font-semibold">
          Browse levels
        </a>
      </div>

      <!-- sample kanji -->
      <div class="mt-12 sm:mt-16 flex flex-wrap justify-center gap-3 sm:gap-4">
        {sampleKanji.map((k, i) => (
          <a
            href={k.url}
            class="card card-hover group px-4 sm:px-6 py-3 sm:py-4 text-center min-w-[80px] sm:min-w-[104px] animate-fade-up"
            style={`animation-delay: ${320 + i * 70}ms`}
          >
            <span class="block text-3xl sm:text-4xl font-jp font-black text-ink transition-transform duration-300 group-hover:scale-110 group-hover:text-vermilion">{k.char}</span>
            <span class="block text-[10px] sm:text-xs text-ink/50 mt-1.5">{k.meaning}</span>
            <span class="block text-[10px] text-ink/30">{k.level}</span>
          </a>
        ))}
      </div>
    </div>
  </section>



  <!-- ———————— Levels ———————— -->
  <section id="levels" class="border-t border-ink/5 scroll-mt-14">
    <div class="max-w-5xl mx-auto px-4 py-16 sm:py-24">
      <h2 class="text-2xl sm:text-4xl font-black text-ink text-center reveal">Choose your level</h2>
      <p class="text-sm sm:text-base text-ink/60 text-center mt-3 max-w-xl mx-auto reveal" style="--reveal-delay: 80ms">
        Every level includes study guides, flashcards, vocabulary, and {SETS_PER_LEVEL} practice tests.
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 mt-10 sm:mt-12">
        {levels.map((l, i) => (
          <a
            href={`/${l.id}/`}
            class="card card-hover group overflow-hidden reveal"
            style={`--reveal-delay: ${i * 80}ms`}
          >
            <div class={`h-1.5 bg-gradient-to-r ${l.gradient}`} />
            <div class="p-5 sm:p-6">
              <div class="flex items-center justify-between mb-4">
                <span class={`w-11 h-11 rounded-xl bg-gradient-to-br ${l.gradient} text-white font-black flex items-center justify-center shadow-lg ${l.glow} transition-transform duration-300 group-hover:scale-110 group-hover:rotate-3`}>
                  {l.label}
                </span>
                <span class="chip">{l.tagline}</span>
              </div>
              <div class="flex gap-4 text-[13px] text-ink/70">
                <span><strong class="text-ink font-bold">{l.kanji.toLocaleString()}</strong> kanji</span>
                <span><strong class="text-ink font-bold">{l.vocab.toLocaleString()}</strong> words</span>
                <span><strong class="text-ink font-bold">{SETS_PER_LEVEL}</strong> tests</span>
              </div>
              <div class="mt-4 pt-3.5 border-t border-ink/5 flex items-center justify-between">
                <span class="text-xs text-ink/50">Start learning</span>
                <span class="text-ink/30 group-hover:text-vermilion group-hover:translate-x-1 transition-all duration-300 text-sm">&rarr;</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ———————— Blog ———————— -->
  {featuredPosts.length > 0 && (
    <section class="border-t border-ink/5">
      <div class="max-w-5xl mx-auto px-4 py-16 sm:py-24">
        <h2 class="text-2xl sm:text-4xl font-black text-ink text-center reveal">From the blog</h2>
        <p class="text-sm sm:text-base text-ink/60 text-center mt-3 max-w-xl mx-auto reveal" style="--reveal-delay: 80ms">
          Study guides, kanji tips, and JLPT strategies to help you learn Japanese.
        </p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 mt-10 sm:mt-12">
          {featuredPosts.map((post, i) => (
            <a href={`/blog/${post.id}/`} class="card card-hover p-5 sm:p-6 reveal" style={`--reveal-delay: ${i * 60}ms`}>
              <h3 class="text-base font-bold text-ink group-hover:text-vermilion transition-colors">{post.data.title}</h3>
              <p class="text-[13px] text-ink/60 mt-1.5 line-clamp-2 leading-relaxed">{post.data.description}</p>
              <span class="inline-flex items-center gap-1 text-xs text-vermilion font-medium mt-3">
                Read more &rarr;
              </span>
            </a>
          ))}
        </div>
        <div class="flex justify-center mt-8">
          <a href="/blog/" class="btn btn-ghost h-11 sm:h-12 px-7 text-sm font-semibold reveal">
            View all articles
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ———————— Tools ———————— -->
  <section class="border-t border-ink/5" style="background:var(--card-bg,#fff)">
    <div class="max-w-5xl mx-auto px-4 py-16 sm:py-24">
      <h2 class="text-2xl sm:text-4xl font-black text-ink text-center reveal">Japanese study tools</h2>
      <p class="text-sm sm:text-base text-ink/60 text-center mt-3 max-w-xl mx-auto reveal" style="--reveal-delay: 80ms">
        Practical tools for kana conversion, kanji lookup, text analysis, and more.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 sm:gap-4 mt-8 sm:mt-10">
        {["🔀", "📖", "🎨", "✅", "⚡", "📅", "⏱️", "🎯", "🎲", "📊"].map((icon, i) => (
          <a href={["/tools/kana-converter/", "/tools/kanji-dictionary/", "/tools/kanji-highlighter/", "/tools/jlpt-score-checker/", "/tools/kanji-flash-quiz/", "/tools/date-converter/", "/tools/study-timer/", "/tools/kana-quiz/", "/tools/random-kanji/", "/tools/text-analyzer/"][i]}
            class="card card-hover group p-4 sm:p-5 text-center reveal"
            style={`--reveal-delay: ${i * 60}ms`}
          >
            <span class="inline-flex w-10 h-10 items-center justify-center rounded-xl bg-ink/[0.04] text-xl transition-transform duration-300 group-hover:scale-110 group-hover:-rotate-6">{icon}</span>
            <p class="text-xs font-bold text-ink mt-2 group-hover:text-vermilion transition-colors">{["Kana Converter", "Kanji Dictionary", "Kanji Highlighter", "Score Checker", "Flash Quiz", "Date Converter", "Study Timer", "Kana Quiz", "Random Kanji", "Text Analyzer"][i]}</p>
          </a>
        ))}
      </div>
      <div class="flex justify-center mt-6">
        <a href="/tools/" class="btn btn-ghost h-10 px-5 text-xs font-semibold reveal">
          View all tools
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ———————— Test CTA ———————— -->
  <section class="relative text-white overflow-hidden" style="background:#221f1a">
    <span aria-hidden="true" class="absolute -left-6 top-1/2 -translate-y-1/2 text-[14rem] leading-none font-jp font-black text-white/[0.04] select-none pointer-events-none">試験</span>
    <div class="relative max-w-5xl mx-auto px-4 py-16 sm:py-24 text-center">
      <h2 class="text-2xl sm:text-4xl font-black reveal">Ready to test yourself?</h2>
      <p class="text-sm sm:text-base text-white/60 mt-3 max-w-lg mx-auto reveal" style="--reveal-delay: 80ms">
        Jump straight into a practice quiz — {QUESTIONS_PER_SET} questions, instant feedback, no sign-up.
      </p>
      <div class="flex flex-wrap justify-center gap-2.5 sm:gap-3 mt-8 sm:mt-10">
        {levels.map((l, i) => (
          <a
            href={`/${l.id}/sets/1/`}
            class="btn h-11 sm:h-12 px-5 sm:px-6 text-xs sm:text-sm text-white bg-white/10 hover:bg-white/20 reveal"
            style={`--reveal-delay: ${120 + i * 60}ms`}
          >
            {l.label} test
            <svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ———————— Kanji by level ———————— -->
  <section class="border-t border-ink/5">
    <div class="max-w-5xl mx-auto px-4 py-16 sm:py-24">
      <h2 class="text-2xl sm:text-4xl font-black text-ink text-center reveal">Kanji by JLPT level</h2>
      <p class="text-sm sm:text-base text-ink/60 text-center mt-3 max-w-xl mx-auto reveal" style="--reveal-delay: 80ms">
        The JLPT spans 5 levels, from N5 (easiest) to N1 (most advanced). Each level adds progressively more kanji.
      </p>

      <div class="mt-10 sm:mt-12 max-w-2xl mx-auto space-y-4">
        {levels.map((l, i) => (
          <div class="flex items-center gap-3 sm:gap-4 reveal" style={`--reveal-delay: ${i * 80}ms`}>
            <span class="w-9 sm:w-11 shrink-0 text-sm sm:text-base font-black text-ink">{l.label}</span>
            <div class="flex-1 h-3.5 sm:h-4 bg-ink/5 rounded-full overflow-hidden">
              <div
                class={`h-full rounded-full bg-gradient-to-r ${l.gradient} progress-bar`}
                style={`--bar-width: ${Math.max(3, Math.round((l.kanji / maxKanji) * 100))}%`}
              />
            </div>
            <div class="flex gap-2.5 shrink-0 text-[11px] sm:text-xs text-ink/60 tabular-nums">
              <span class="w-16 text-right">{l.kanji.toLocaleString()} kanji</span>
              <span class="hidden sm:inline w-20 text-right">{l.vocab.toLocaleString()} words</span>
            </div>
          </div>
        ))}
      </div>

      <div class="flex justify-center mt-10 sm:mt-12">
        <a href="/about/" class="btn btn-ghost h-11 sm:h-12 px-7 text-sm font-semibold reveal">
          Learn more about the platform
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>
</DefaultLayout>

<style>
  /* Bars grow to their width once the reveal wrapper becomes visible */
  .progress-bar {
    width: 0;
    transition: width 1.1s var(--ease-out-expo) 0.15s;
  }
  :global(html.js .reveal.is-visible) .progress-bar,
  :global(html:not(.js)) .progress-bar {
    width: var(--bar-width);
  }
</style>
