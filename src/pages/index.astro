---
import DefaultLayout from "@/layouts/DefaultLayout.astro"
import { siteUrl, collectionPageSchema } from "@/lib/seo"

const levels = [
  { id: "n5", label: "N5", kanji: 79, vocab: 219, desc: "Basic Japanese characters for beginners" },
  { id: "n4", label: "N4", kanji: 171, vocab: 473, desc: "Intermediate Japanese characters" },
  { id: "n3", label: "N3", kanji: 367, vocab: 935, desc: "Upper-intermediate Japanese characters" },
  { id: "n2", label: "N2", kanji: 984, vocab: 3432, desc: "Advanced Japanese characters" },
  { id: "n1", label: "N1", kanji: 2215, vocab: 9250, desc: "Master-level Japanese characters" },
]

const jsonLd = collectionPageSchema(
  "Free JLPT Kanji Test Online — KanjiTest.Online",
  "Free JLPT N5, N4, N3, N2, and N1 kanji tests with answers. Study with flashcards, vocabulary, and practice quizzes.",
  "/"
)
---

<DefaultLayout
  title="Free JLPT Kanji Study, Quiz & Test — N5, N4, N3, N2 & N1"
  description="Master JLPT N5, N4, N3, N2, and N1 kanji with KanjiTest.Online — study with example words, flip flashcards, test your knowledge. Free forever."
>
  <div class="max-w-4xl mx-auto px-4 py-8 sm:py-12">
    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />

    <!-- Hero -->
    <div class="text-center mb-10 sm:mb-14">
      <h1 class="text-3xl sm:text-5xl font-black text-ink leading-tight">
        Free JLPT Kanji <span class="text-blue-500">Test</span> Online
      </h1>
      <p class="text-sm sm:text-lg text-ink/70 mt-2 sm:mt-3 font-medium">
        N5 Kanji Test · N4 Kanji Test · N3 Kanji Test · N2 Kanji Test · N1 Kanji Test with answers
      </p>
      <p class="text-xs sm:text-sm text-ink/50 mt-1.5 sm:mt-2">
        Study, Flashcards, Vocabulary & Practice Quizzes — Free forever
      </p>
    </div>

    <!-- Level quick-nav -->
    <div class="flex flex-wrap justify-center gap-1.5 sm:gap-3 mb-12 sm:mb-16 px-2">
      {levels.map((l) => (
        <a
          key={l.id}
          href={`#${l.id}`}
          class="h-10 sm:h-14 px-3 sm:px-8 bg-ink text-white rounded-xl text-xs sm:text-base font-bold flex items-center hover:bg-ink/80 transition-all shrink-0"
        >
          Kanji {l.label}
        </a>
      ))}
      <a
        href="#why"
        class="h-10 sm:h-14 px-3 sm:px-8 border border-ink/20 rounded-xl text-xs sm:text-base font-medium text-ink/70 flex items-center hover:border-ink/40 transition-all shrink-0"
      >
        Why?
      </a>
    </div>

    <!-- Per-level sections -->
    {levels.map((l) => (
      <section key={l.id} id={l.id} class="mb-10 sm:mb-12 scroll-mt-20">
        <div class="border border-ink/20 rounded-2xl bg-white overflow-hidden">
          <div class="px-5 sm:px-7 py-5 sm:py-6 border-b border-ink/10">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
              <div>
                <h2 class="text-xl sm:text-2xl font-black text-ink">JLPT {l.label} Kanji Test</h2>
                <p class="text-xs sm:text-sm text-ink/60 mt-0.5">{l.kanji} kanji · {l.vocab} words · 20 tests</p>
              </div>
              <p class="text-xs sm:text-sm text-ink/50 italic">{l.desc}</p>
            </div>
          </div>

          <div class="px-5 sm:px-7 py-4 sm:py-5 border-b border-ink/10">
            <div class="flex flex-wrap gap-1.5 sm:gap-2">
              <a href={`/${l.id}/study/`} class="h-9 sm:h-10 px-3 sm:px-4 bg-ink/10 text-ink rounded-lg text-xs sm:text-sm font-medium flex items-center gap-1.5 hover:bg-ink/20 transition-all">
                📖 Study
              </a>
              <a href={`/${l.id}/flashcards/`} class="h-9 sm:h-10 px-3 sm:px-4 bg-ink/10 text-ink rounded-lg text-xs sm:text-sm font-medium flex items-center gap-1.5 hover:bg-ink/20 transition-all">
                🃏 Flashcards
              </a>
              <a href={`/${l.id}/vocabulary/`} class="h-9 sm:h-10 px-3 sm:px-4 bg-ink/10 text-ink rounded-lg text-xs sm:text-sm font-medium flex items-center gap-1.5 hover:bg-ink/20 transition-all">
                📝 Vocabulary
              </a>
            </div>
          </div>

          <div class="px-5 sm:px-7 py-4 sm:py-5">
            <p class="text-xs font-medium uppercase tracking-widest text-ink/50 mb-3">Practice Tests (10 minutes each)</p>
            <div class="flex flex-wrap gap-2">
              {Array.from({ length: 20 }, (_, i) => i + 1).map((n) => (
                <a
                  key={n}
                  href={`/${l.id}/sets/${n}/`}
                  class="inline-flex items-center gap-1.5 h-9 sm:h-10 px-3 sm:px-4 border border-ink/20 rounded-lg text-xs sm:text-sm text-ink/70 hover:border-ink/40 hover:text-ink transition-all bg-white"
                >
                  Test {n}
                  <span class="text-[10px] text-ink/40">&rarr;</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>
    ))}

    <!-- Why Learn Kanji -->
    <section id="why" class="mb-10 sm:mb-12 scroll-mt-20">
      <div class="border-t border-ink/20 pt-8 sm:pt-10">
        <h2 class="text-lg sm:text-xl font-bold text-ink mb-4">Why You Should Learn Kanji</h2>
        <p class="text-xs sm:text-sm text-ink/70 leading-relaxed mb-5">
          In Japanese, there are about 2,000 common kanji characters. Kanji is arguably the most prominent part
          of the Japanese writing system. The elegant characters, originally adapted from Chinese, make up most
          of written Japanese. You can see them in books, magazines, on signs, and everywhere. Understanding
          kanji is essential to fully comprehend the Japanese language and culture.
        </p>
      </div>
    </section>

    <!-- Kanji by JLPT Level -->
    <section class="mb-10 sm:mb-12">
      <div class="border-t border-ink/20 pt-8 sm:pt-10">
        <h2 class="text-lg sm:text-xl font-bold text-ink mb-4">Kanji by JLPT Level</h2>
        <p class="text-xs sm:text-sm text-ink/70 leading-relaxed mb-5">
          The Japanese-Language Proficiency Test (JLPT) is the main standardized test of Japanese ability for
          non-native speakers. It is composed of 5 levels, from N5 (most basic) to N1 (most advanced).
        </p>
        <div class="space-y-2.5">
          <div class="flex items-center gap-3 sm:gap-4">
            <span class="w-8 sm:w-10 shrink-0 text-sm sm:text-base font-bold text-ink">N5</span>
            <div class="flex-1 h-2 sm:h-2.5 bg-ink/10 rounded-full overflow-hidden">
              <div class="h-full bg-ink rounded-full" style="width: 4%" />
            </div>
            <span class="w-24 sm:w-32 shrink-0 text-[11px] sm:text-xs text-ink/60 text-right">~100 kanji</span>
          </div>
          <div class="flex items-center gap-3 sm:gap-4">
            <span class="w-8 sm:w-10 shrink-0 text-sm sm:text-base font-bold text-ink">N4</span>
            <div class="flex-1 h-2 sm:h-2.5 bg-ink/10 rounded-full overflow-hidden">
              <div class="h-full bg-ink rounded-full" style="width: 15%" />
            </div>
            <span class="w-24 sm:w-32 shrink-0 text-[11px] sm:text-xs text-ink/60 text-right">~300 kanji</span>
          </div>
          <div class="flex items-center gap-3 sm:gap-4">
            <span class="w-8 sm:w-10 shrink-0 text-sm sm:text-base font-bold text-ink">N3</span>
            <div class="flex-1 h-2 sm:h-2.5 bg-ink/10 rounded-full overflow-hidden">
              <div class="h-full bg-ink rounded-full" style="width: 33%" />
            </div>
            <span class="w-24 sm:w-32 shrink-0 text-[11px] sm:text-xs text-ink/60 text-right">~650 kanji</span>
          </div>
          <div class="flex items-center gap-3 sm:gap-4">
            <span class="w-8 sm:w-10 shrink-0 text-sm sm:text-base font-bold text-ink">N2</span>
            <div class="flex-1 h-2 sm:h-2.5 bg-ink/10 rounded-full overflow-hidden">
              <div class="h-full bg-ink rounded-full" style="width: 50%" />
            </div>
            <span class="w-24 sm:w-32 shrink-0 text-[11px] sm:text-xs text-ink/60 text-right">~1,000 kanji</span>
          </div>
          <div class="flex items-center gap-3 sm:gap-4">
            <span class="w-8 sm:w-10 shrink-0 text-sm sm:text-base font-bold text-ink">N1</span>
            <div class="flex-1 h-2 sm:h-2.5 bg-ink/10 rounded-full overflow-hidden">
              <div class="h-full bg-ink rounded-full" style="width: 100%" />
            </div>
            <span class="w-24 sm:w-32 shrink-0 text-[11px] sm:text-xs text-ink/60 text-right">~2,000 kanji</span>
          </div>
        </div>
      </div>
    </section>
  </div>
</DefaultLayout>
