---
import DefaultLayout from "@/layouts/DefaultLayout.astro"
import { radicals, toSlug } from "@/lib/radicals"

const groups = radicals.reduce<{ strokes: number; items: typeof radicals }[]>((acc, r) => {
  const g = acc.find((g) => g.strokes === r.strokes)
  if (g) g.items.push(r)
  else acc.push({ strokes: r.strokes, items: [r] })
  return acc
}, [])
---

<DefaultLayout title="Japanese Radicals — KanjiTest.Online" description="The 214 traditional Kangxi radicals used in Japanese kanji. Complete reference with stroke counts and meanings." keywords="Kangxi radicals, Japanese radicals, kanji radicals, radical chart, 214 radicals, kanji components, bujō">
  <div class="max-w-5xl mx-auto px-4 py-8 sm:py-12">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between mb-6 animate-fade-up">
      <div class="min-w-0">
        <h1 class="text-xl sm:text-2xl font-black text-ink">Radicals <span class="text-base sm:text-lg font-medium text-ink/40">部首</span></h1>
        <p class="text-xs sm:text-sm text-ink/55 mt-1">{radicals.length} radicals · 214 Kangxi radicals · The building blocks of kanji</p>
      </div>
    </div>

    <div class="card p-4 mb-6 animate-fade-up">
      <h2 class="text-xs font-bold text-ink/50 uppercase tracking-widest mb-2">How to use this guide</h2>
      <ul class="space-y-1 text-[12px] text-ink/60 leading-relaxed">
        <li><span class="font-bold text-ink">Reading</span> — the Japanese name for the radical</li>
        <li><span class="font-bold text-ink">Variants</span> — alternative shapes (e.g. 人 → 亻)</li>
        <li><span class="font-bold text-ink">Examples</span> — common kanji that use this radical</li>
        <li><span class="font-bold text-ink">Tips</span> — mnemonic hints to remember the meaning</li>
      </ul>
    </div>

    <div class="space-y-8">
      {groups.map((g, gi) => (
        <section class="animate-fade-up" style={`animation-delay: ${gi * 30 + 80}ms`}>
          <div class="flex items-center gap-3 mb-3">
            <h2 class="text-sm font-bold text-ink/50 uppercase tracking-widest">{g.strokes} stroke{g.strokes > 1 ? "s" : ""}</h2>
            <span class="flex-1 h-px bg-ink/10" />
            <span class="text-xs text-ink/30">{g.items.length} radicals</span>
          </div>
          <div class="space-y-2">
            {g.items.map((r) => (
              <a href={`/learn/radicals/${toSlug(r.radical)}/`} class="card card-hover group px-3 sm:px-5 py-2.5 sm:py-3 flex items-center gap-3 sm:gap-4 no-underline reveal">
                <span class="w-10 h-10 sm:w-11 sm:h-11 rounded-xl bg-ink/[0.06] flex items-center justify-center shrink-0 text-lg sm:text-xl font-jp font-bold text-ink transition-transform duration-300 group-hover:scale-110">
                  {r.radical}
                </span>
                <span class="flex-1 min-w-0">
                  <span class="flex items-baseline gap-2">
                    <span class="text-sm sm:text-[15px] font-bold text-ink group-hover:text-vermilion transition-colors">{r.meaning}</span>
                    <span class="text-[11px] sm:text-xs text-ink/60 truncate">{r.reading}</span>
                  </span>
                  <span class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5 mt-0.5">
                    {r.variants.length > 0 && (
                      <span class="text-[11px] text-ink/40">
                        variants: {r.variants.map((v) => <span class="font-jp">{v}</span>).join(" ")}
                      </span>
                    )}
                    <span class="text-[10px] text-ink/30">{r.desc}</span>
                  </span>
                  <div class="flex flex-wrap gap-1 mt-1">
                    {r.examples.slice(0, 4).map((ex) => (
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded-md bg-ink/[0.04] text-[10px] sm:text-[11px] font-jp font-medium text-ink/50">{ex}</span>
                    ))}
                    {r.examples.length > 4 && <span class="text-[10px] text-ink/30">+{r.examples.length - 4}</span>}
                  </div>
                </span>
                <span class="text-[10px] text-ink/30 shrink-0 tabular-nums">#{r.id}</span>
                <span class="text-ink/25 shrink-0 text-sm transition-all duration-300 group-hover:text-vermilion group-hover:translate-x-0.5">&rarr;</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</DefaultLayout>
