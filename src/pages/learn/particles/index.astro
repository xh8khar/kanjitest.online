---
import DefaultLayout from "@/layouts/DefaultLayout.astro"
import { particles, getByType, TYPES } from "@/lib/particles"

const TYPE_LABELS: Record<string, string> = {
  Case: "Case Particles (格助詞)",
  Focus: "Focus Particles (取り立て助詞)",
  Conjunctive: "Conjunctive Particles (接続助詞)",
  Final: "Sentence-Final Particles (終助詞)",
  Adverbial: "Adverbial Particles (副助詞)",
  Compound: "Compound Particles",
}

const TYPE_COLORS: Record<string, string> = {
  Case: "bg-blue-50 text-blue-700",
  Focus: "bg-amber-50 text-amber-700",
  Conjunctive: "bg-emerald-50 text-emerald-700",
  Final: "bg-violet-50 text-violet-700",
  Adverbial: "bg-cyan-50 text-cyan-700",
  Compound: "bg-rose-50 text-rose-700",
}
---

<DefaultLayout
  title="Japanese Particles — Complete Reference — KanjiTest.Online"
  description="Complete reference for all Japanese particles — case, focus, conjunctive, sentence-final, adverbial, and compound particles with examples and usage."
  keywords="Japanese particles, Japanese grammar particles, wa ga, Japanese particle list, JLPT particles, Japanese particle guide"
>
  <div class="max-w-5xl mx-auto px-4 py-8 sm:py-12">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between mb-6 animate-fade-up">
      <div class="min-w-0">
        <h1 class="text-xl sm:text-2xl font-black text-ink">Particles <span class="text-base sm:text-lg font-medium text-ink/40">助詞</span></h1>
        <p class="text-xs sm:text-sm text-ink/55 mt-1">{particles.length} particles · Case · Focus · Conjunctive · Final · Adverbial · Compound</p>
      </div>
    </div>

    <div class="space-y-8">
      {TYPES.map((type, ti) => {
        const items = getByType(type)
        return (
          <section class="animate-fade-up" style={`animation-delay: ${ti * 60}ms`}>
            <div class="flex items-center gap-3 mb-3">
              <h2 class="text-sm font-bold text-ink/50 uppercase tracking-widest">{TYPE_LABELS[type]}</h2>
              <span class="flex-1 h-px bg-ink/10" />
              <span class="text-xs text-ink/30">{items.length} particles</span>
            </div>
            <div class="space-y-2">
              {items.map((p) => (
                <a href={`/learn/particles/${p.id}/`} class="card card-hover group px-3 sm:px-5 py-2.5 sm:py-3 flex items-center gap-3 sm:gap-4 no-underline reveal">
                  <span class={`w-10 h-10 sm:w-11 sm:h-11 rounded-xl ${TYPE_COLORS[type]} flex items-center justify-center shrink-0 text-lg sm:text-xl font-jp font-bold transition-transform duration-300 group-hover:scale-110`}>
                    {p.particle}
                  </span>
                  <span class="flex-1 min-w-0">
                    <span class="flex items-baseline gap-2">
                      <span class="text-sm sm:text-[15px] font-bold text-ink group-hover:text-vermilion transition-colors">{p.meaning}</span>
                      <span class="text-[11px] sm:text-xs text-ink/60 truncate">{p.reading}</span>
                    </span>
                    <span class="block text-[11px] sm:text-xs text-ink/50 mt-0.5 truncate">{p.summary}</span>
                  </span>
                  <span class="text-[10px] text-ink/30 shrink-0 tabular-nums uppercase">{p.jlpt}</span>
                  <span class="text-ink/25 shrink-0 text-sm transition-all duration-300 group-hover:text-vermilion group-hover:translate-x-0.5">&rarr;</span>
                </a>
              ))}
            </div>
          </section>
        )
      })}
    </div>

    <div class="text-center mt-8 animate-fade-up">
      <a href="/learn/" class="inline-flex items-center gap-1.5 text-xs text-ink/50 hover:text-ink transition-colors">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
        Back to Learn
      </a>
    </div>
  </div>
</DefaultLayout>
