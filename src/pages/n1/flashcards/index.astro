---
import DefaultLayout from "@/layouts/DefaultLayout.astro"
import { getAll } from "@/lib/kanji"


const level = "n1"
const all = getAll(level)

const title = `JLPT N1 Kanji Flashcards — Flip & Memorize`
const description = `Flip through all ${all.length} JLPT N1 kanji flashcards. Tap to reveal readings and meanings. Track your progress with Know/Again.`
---

<DefaultLayout title={title} description={description} level={level}>
  <meta http-equiv="refresh" content={`0;url=/${level}/flashcards/${encodeURIComponent(all[0].kanji)}/`} />
</DefaultLayout>
