---
import BaseLayout from "@/layouts/BaseLayout.astro"
import TestClient from "@/components/TestClient"


export function getStaticPaths() {
  return Array.from({ length: 20 }, (_, i) => ({ params: { set: String(i + 1) } }))
}

const level = "n1"
const { set } = Astro.params
const setNum = parseInt(set!)
const title = `Kanji Test Online – JLPT N1 Kanji Quiz Set ${setNum} (20 Questions)`
const description = `Practice JLPT N1 kanji with Set ${setNum} of 20 questions. Test your kanji-to-reading and reading-to-kanji skills.`
---

<BaseLayout {title} {description}>
  <TestClient setNum={setNum} level={level} client:load />
</BaseLayout>
