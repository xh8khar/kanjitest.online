---
import BaseLayout from "@/layouts/BaseLayout.astro"
import LevelLayout from "@/layouts/LevelLayout.astro"
import { getVocabulary } from "@/lib/kanji"
import { collectionPageSchema, itemListSchema } from "@/lib/seo"

const level = "n1"
const vocab = getVocabulary(level)
const sorted = [...vocab].sort((a, b) => a.reading.localeCompare(b.reading, "ja"))
const items = sorted.map((v) => ({ name: `${v.word} (${v.reading}) — ${v.english}`, url: `/${level}/vocabulary/${v.slug}/` }))
const pageSchema = collectionPageSchema(`JLPT N1 Vocabulary — ${sorted.length} Words with Readings`, `Complete JLPT N1 vocabulary list with readings, meanings, and associated kanji.`, `/${level}/vocabulary`)
const listSchema = itemListSchema(items)
const title = `JLPT N1 Vocabulary — ${sorted.length} Words with Readings`
const description = `Complete JLPT N1 vocabulary list with readings, meanings, and associated kanji. Browse ${sorted.length} essential Japanese words.`
---

<BaseLayout {title} {description}>
  <LevelLayout {level}>
    <script set:html={JSON.stringify(pageSchema)} type="application/ld+json" />
    <script set:html={JSON.stringify(listSchema)} type="application/ld+json" />

    <div class="px-4 py-6 sm:py-8">
      <h1 class="text-lg sm:text-xl font-bold text-ink">Vocabulary</h1>
      <p class="text-xs text-ink/60 mt-1 mb-5 sm:mb-6">{sorted.length} words</p>

      <div class="space-y-1.5 sm:space-y-2">
        {sorted.map((v, i) => (
          <a
            key={`${v.word}|${v.reading}`}
            href={`/${level}/vocabulary/${v.slug}/`}
            class="border border-ink/20 rounded-lg sm:rounded-xl px-3 sm:px-5 py-2.5 sm:py-3 bg-white flex items-center gap-2 sm:gap-4 hover:border-ink/40 transition-all"
          >
            <div class="w-7 h-7 rounded-md bg-ink/10 flex items-center justify-center shrink-0">
              <span class="text-[11px] sm:text-xs font-medium text-ink/60">{i + 1}</span>
            </div>
            <div class="flex-1 min-w-0">
              <span class="text-base sm:text-lg font-bold text-ink leading-none">{v.word}</span>
              <span class="text-[11px] sm:text-xs text-ink/60 ml-1.5 sm:ml-2">({v.english})</span>
              <p class="text-[11px] sm:text-xs text-ink/70 mt-0.5">{v.reading}</p>
            </div>
            <div class="flex gap-0.5 sm:gap-1 shrink-0">
              {v.kanjiIds.map((id, idx) => (
                <div
                  key={id}
                  class="w-5 h-5 sm:w-6 sm:h-6 rounded bg-ink/10 text-[10px] sm:text-xs font-bold text-ink/70 flex items-center justify-center"
                >
                  {v.kanjiChars[idx]}
                </div>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </LevelLayout>
</BaseLayout>
