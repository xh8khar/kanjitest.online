---
import BaseLayout from "@/layouts/BaseLayout.astro"
import LevelLayout from "@/layouts/LevelLayout.astro"
import { getAll, getVocabulary } from "@/lib/kanji"
import { siteUrl, collectionPageSchema, itemListSchema, keywords as kw } from "@/lib/seo"

const level = "n1"
const all = getAll(level)
const items = all.map((k) => ({ name: `${k.kanji} — ${k.meanings[0]}`, url: `/${level}/study/${k.kanji}/` }))
const pageSchema = collectionPageSchema(`JLPT N1 Kanji Hub — All ${all.length} Characters`, `Browse all ${all.length} JLPT N1 kanji with readings and examples.`, `/${level}`)
const listSchema = itemListSchema(items)
const title = `JLPT N1 Kanji — All ${all.length} Characters`
const description = `Browse all ${all.length} JLPT N1 kanji with kun/on readings, example words, and daily-life sentences. Study, flashcard, and test yourself.`
---

<BaseLayout {title} {description}>
  <LevelLayout {level}>
    <script set:html={JSON.stringify(pageSchema)} type="application/ld+json" />
    <script set:html={JSON.stringify(listSchema)} type="application/ld+json" />

    <div class="px-4 py-6 sm:py-8">
      <h1 class="text-lg sm:text-xl font-bold text-ink">All {all.length} Kanji</h1>
      <p class="text-xs sm:text-sm text-ink/60 mt-1 mb-6 sm:mb-8">JLPT N1 — master-level Japanese characters</p>

      <div class="flex gap-1.5 sm:grid sm:grid-cols-3 md:grid-cols-4 overflow-x-auto pb-1 sm:pb-0 sm:gap-3 mb-6 sm:mb-10 scrollbar-none">
        <a href={`/${level}/study/`} class="shrink-0 sm:shrink border border-ink/20 rounded-xl px-3 sm:px-5 py-2.5 sm:py-5 bg-white hover:border-ink/40 transition-all sm:text-center flex sm:block items-center gap-2">
          <span class="text-base sm:text-xl">📖</span>
          <p class="font-medium text-xs sm:text-sm text-ink sm:mt-2">Study</p>
          <p class="hidden sm:block text-xs text-ink/70 mt-0.5">{all.length} characters</p>
        </a>
        <a href={`/${level}/flashcards/`} class="shrink-0 sm:shrink border border-ink/20 rounded-xl px-3 sm:px-5 py-2.5 sm:py-5 bg-white hover:border-ink/40 transition-all sm:text-center flex sm:block items-center gap-2">
          <span class="text-base sm:text-xl">🃏</span>
          <p class="font-medium text-xs sm:text-sm text-ink sm:mt-2">Flashcards</p>
          <p class="hidden sm:block text-xs text-ink/70 mt-0.5">Flip & memorize</p>
        </a>
        <a href={`/${level}/vocabulary/`} class="shrink-0 sm:shrink border border-ink/20 rounded-xl px-3 sm:px-5 py-2.5 sm:py-5 bg-white hover:border-ink/40 transition-all sm:text-center flex sm:block items-center gap-2">
          <span class="text-base sm:text-xl">📝</span>
          <p class="font-medium text-xs sm:text-sm text-ink sm:mt-2">Vocabulary</p>
          <p class="hidden sm:block text-xs text-ink/70 mt-0.5">{getVocabulary(level).length} words</p>
        </a>
        <a href={`/${level}/sets/`} class="shrink-0 sm:shrink border border-ink/20 rounded-xl px-3 sm:px-5 py-2.5 sm:py-5 bg-white hover:border-ink/40 transition-all sm:text-center flex sm:block items-center gap-2">
          <span class="text-base sm:text-xl">✍️</span>
          <p class="font-medium text-xs sm:text-sm text-ink sm:mt-2">Tests</p>
          <p class="hidden sm:block text-xs text-ink/70 mt-0.5">20 sets</p>
        </a>
      </div>

      <div class="grid grid-cols-5 sm:grid-cols-6 md:grid-cols-8 lg:grid-cols-10 gap-1.5 sm:gap-2">
        {all.map((k) => (
          <a
            key={k.id}
            href={`/${level}/study/${k.kanji}/`}
            class="border border-ink/20 rounded-lg p-2 sm:p-3 text-center hover:border-ink/40 transition-all bg-white"
          >
            <div class="text-base sm:text-lg font-bold text-ink leading-none">{k.kanji}</div>
            <div class="text-[10px] text-ink/60 mt-0.5 leading-tight">
              {k.kun[0]?.replace(/\..+$/, "") || k.on[0]}
            </div>
          </a>
        ))}
      </div>
    </div>
  </LevelLayout>
</BaseLayout>
