---
import GrammarDetailPage from "@/components/level/GrammarDetailPage.astro"
import { getGrammar } from "@/lib/grammar"

export function getStaticPaths() {
  return getGrammar("n4").map((g) => ({ params: { slug: g.id } }))
}

const slug = decodeURIComponent(Astro.params.slug!)
---

<GrammarDetailPage level="n4" id={slug} />
