---
import DefaultLayout from "@/layouts/DefaultLayout.astro"
import { getAll } from "@/lib/kanji"

const level = "n4"
const all = getAll(level)

const title = `JLPT N4 Kanji Flashcards — Flip & Memorize`
const description = `Flip through all ${all.length} JLPT N4 kanji flashcards. Tap to reveal readings and meanings. Track your progress with Know/Again.`
---

<DefaultLayout {title} {description} level={level}>
  <div class="px-4 py-6 sm:py-8">
    <h1 class="text-lg sm:text-xl font-bold text-ink">Flashcards</h1>
    <p class="text-xs text-ink/60 mt-1 mb-5 sm:mb-6">{all.length} cards</p>
    <div class="space-y-1.5 sm:space-y-2">
      {all.map((k) => (
        <a key={k.id} href={`/${level}/flashcards/${k.kanji}/`} class="border border-ink/20 rounded-lg sm:rounded-xl px-3 sm:px-5 py-2.5 sm:py-3 bg-white flex items-center gap-2 sm:gap-4 hover:border-ink/40 transition-all">
          <div class="w-7 h-7 rounded-md bg-ink/10 flex items-center justify-center shrink-0">
            <span class="text-[11px] sm:text-xs font-medium text-ink/60">{k.id}</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-baseline gap-2 sm:gap-3">
              <span class="text-base sm:text-lg font-bold text-ink leading-none">{k.kanji}</span>
              <span class="text-[11px] sm:text-xs text-ink/70 truncate">
                {k.kun.map((r) => r.replace(/\..+$/, "")).join("、") || k.on.join("、")}
              </span>
            </div>
            <p class="text-[11px] sm:text-xs text-ink/60 mt-0.5 truncate">{k.meanings[0]}</p>
          </div>
          <span class="text-ink/30 shrink-0 text-sm">&rarr;</span>
        </a>
      ))}
    </div>
  </div>
</DefaultLayout>
