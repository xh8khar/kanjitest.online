---
import KanjiDetailPage from "@/components/level/KanjiDetailPage.astro"
import { getAll } from "@/lib/kanji"

export function getStaticPaths() {
  return getAll("n4").map((k) => ({ params: { kanji: k.kanji } }))
}

const kanji = decodeURIComponent(Astro.params.kanji!)
---

<KanjiDetailPage level="n4" kanji={kanji} />
