---
import DefaultLayout from "@/layouts/DefaultLayout.astro"
import { siteUrl, webPageSchema, breadcrumbSchema } from "@/lib/seo"
---

<DefaultLayout
  title="About KanjiTest.Online — Free JLPT Kanji Practice & Quiz Platform"
  description="Learn about KanjiTest.Online — a free JLPT kanji test and study platform with flashcards, vocabulary, and practice quizzes for N5, N4, N3, N2, and N1."
>
  <div class="max-w-3xl mx-auto px-4 py-8 sm:py-12">
    <script
      type="application/ld+json"
      set:html={JSON.stringify(webPageSchema("About | KanjiTest.Online", "About KanjiTest.Online — a free JLPT kanji study platform."))}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbSchema([
        { name: "Home", url: siteUrl("/") },
        { name: "About", url: siteUrl("/about/") },
      ]))}
    />

    <h1 class="text-3xl sm:text-4xl font-black text-ink mb-6">About KanjiTest.Online</h1>

    <div class="space-y-5 text-sm sm:text-base text-ink/80 leading-relaxed">
      <p>
        KanjiTest.Online is a free, independent study platform designed to help Japanese language learners master
        JLPT kanji at every level — from N5 to N1. Our mission is to make kanji learning accessible, structured,
        and effective for anyone, anywhere in the world.
      </p>

      <p>
        Whether you are just starting with basic N5 characters or drilling advanced N1 kanji, our tools give you
        everything you need: detailed study pages with readings and example words, flip flashcards for active recall,
        vocabulary lists with sentence examples, and timed practice tests with instant feedback.
      </p>

      <p>
        We believe language learning should never be locked behind a paywall. That is why KanjiTest.Online is
        and always will be <strong class="text-ink font-semibold">completely free</strong>. No subscriptions,
        no hidden fees, no account required.
      </p>

      <h2 class="text-xl font-bold text-ink mt-8 mb-3">Contact</h2>
      <p>
        Have questions, suggestions, or feedback? We would love to hear from you.
        Reach out at <a href="mailto:hello@kanjitest.online" class="text-blue-600 underline hover:text-blue-800">hello@kanjitest.online</a>.
      </p>
    </div>
  </div>
</DefaultLayout>
