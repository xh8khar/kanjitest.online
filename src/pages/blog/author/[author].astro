---
import DefaultLayout from "@/layouts/DefaultLayout.astro"
import { siteUrl, collectionPageSchema, breadcrumbSchema } from "@/lib/seo"
import { getCollection } from "astro:content"
import { LEVELS, LEVEL_IDS } from "@/lib/levels"

export async function getStaticPaths() {
  const allPosts = await getCollection("blog")
  const allAuthors = new Set<string>()
  for (const post of allPosts) {
    if (!post.data.draft) {
      allAuthors.add(post.data.author)
    }
  }
  return Array.from(allAuthors).map((author) => ({
    params: { author },
  }))
}

const { author } = Astro.params
const allPosts = await getCollection("blog")
const published = allPosts
  .filter((p) => !p.data.draft && p.data.author.toLowerCase() === author!.toLowerCase())
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((p) => ({ ...p, slug: p.id }))

const jsonLd = collectionPageSchema(
  `Posts by ${author} — KanjiTest.Online Blog`,
  `All blog posts by ${author} on KanjiTest.Online — JLPT study tips, kanji learning guides, and Japanese language resources.`,
  `/blog/author/${author}/`
)
---

<DefaultLayout
  title={`Posts by ${author} — KanjiTest.Online Blog`}
  description={`Browse all articles written by ${author} — JLPT kanji study guides, tips, and resources on KanjiTest.Online.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema([
      { name: "Home", url: siteUrl("/") },
      { name: "Blog", url: siteUrl("/blog/") },
      { name: `Author: ${author}`, url: siteUrl(`/blog/author/${author}/`) },
    ]))}
  />

  <div class="max-w-4xl mx-auto px-4 py-8 sm:py-12">
    <div class="mb-6">
      <a href="/blog/" class="text-sm text-ink/50 hover:text-vermilion transition-colors">&larr; Back to blog</a>
    </div>

    <h1 class="text-3xl sm:text-4xl font-black text-ink mb-2">Posts by <span class="text-vermilion">{author}</span></h1>
    <p class="text-sm sm:text-base text-ink/60 max-w-2xl">
      {published.length} {published.length === 1 ? "article" : "articles"} by {author}
    </p>

    <div class="mt-8 sm:mt-10 space-y-6">
      {published.map((post, i) => {
        const { data, slug } = post
        const tagColors: Record<string, string> = {
          JLPT: "bg-emerald-500/10 text-emerald-700",
          N5: "bg-emerald-500/10 text-emerald-700",
          N4: "bg-sky-500/10 text-sky-700",
          N3: "bg-violet-500/10 text-violet-700",
          N2: "bg-orange-500/10 text-orange-700",
          N1: "bg-rose-500/10 text-rose-700",
          beginner: "bg-emerald-500/10 text-emerald-700",
          intermediate: "bg-violet-500/10 text-violet-700",
          advanced: "bg-rose-500/10 text-rose-700",
        }
        return (
          <a
            href={`/blog/${slug}/`}
            class="card card-hover block p-5 sm:p-6 reveal"
            style={`--reveal-delay: ${i * 60}ms`}
          >
            <div class="flex items-center gap-3 text-xs text-ink/40 mb-2.5">
              <time datetime={data.date.toISOString()}>
                {data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
              </time>
              {data.tags.filter((t) => !["N5", "N4", "N3", "N2", "N1"].includes(t)).length > 0 && (
                <span class="flex gap-1.5">
                  {data.tags.filter((t) => !["N5", "N4", "N3", "N2", "N1"].includes(t)).slice(0, 2).map((tag) => (
                    <span class:list={["px-2 py-0.5 rounded-full font-medium", tagColors[tag] || "bg-ink/5 text-ink/60"]}>
                      {tag}
                    </span>
                  ))}
                </span>
              )}
            </div>
            <h2 class="text-lg sm:text-xl font-bold text-ink group-hover:text-vermilion transition-colors">
              {data.title}
            </h2>
            <p class="text-sm text-ink/60 mt-2 leading-relaxed line-clamp-2">
              {data.description}
            </p>
            <div class="mt-3 flex items-center gap-2 text-xs text-ink/40">
              <span>{data.author}</span>
              <span>&middot;</span>
              <span class="text-vermilion font-medium">Read more &rarr;</span>
            </div>
          </a>
        )
      })}
    </div>
  </div>
</DefaultLayout>
