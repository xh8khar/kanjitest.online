---
import DefaultLayout from "@/layouts/DefaultLayout.astro"
import { getAll } from "@/lib/kanji"

const n5data = getAll("n5")
---

<DefaultLayout
  title="JLPT N5 Kanji Checklist — Free Printable PDF"
  description="Complete JLPT N5 kanji checklist. 100+ kanji with readings, meanings, and checkboxes. Free printable PDF for your Japanese study."
  keywords="N5 kanji checklist, JLPT N5 kanji list printable, free N5 kanji PDF, JLPT N5 kanji, N5 kanji list"
>
  <div class="max-w-4xl mx-auto px-4 py-8 sm:py-12">
    <div class="text-center mb-8 animate-fade-up">
      <h1 class="text-3xl sm:text-4xl font-black text-ink">JLPT N5 Kanji Checklist</h1>
      <p class="text-sm text-ink/60 mt-2">All {n5data.length} N5 kanji with readings and meanings. Check off the ones you've mastered!</p>
      <button id="print-btn" class="btn btn-accent h-10 px-5 text-sm mt-4">🖨️ Print / Save PDF</button>
    </div>

    <div id="checklist" class="animate-fade-up" style="animation-delay:80ms">
      <table class="w-full border-collapse">
        <thead>
          <tr class="text-[11px] font-bold uppercase tracking-widest text-ink/40 border-b border-ink/10">
            <th class="py-2 pr-2 text-left w-10">#</th>
            <th class="py-2 px-2 text-left">Kanji</th>
            <th class="py-2 px-2 text-left">Meaning</th>
            <th class="py-2 px-2 text-left hidden sm:table-cell">Kun'yomi</th>
            <th class="py-2 px-2 text-left hidden sm:table-cell">On'yomi</th>
            <th class="py-2 pl-2 text-center w-10">✓</th>
          </tr>
        </thead>
        <tbody>
          {n5data.map((k, i) => (
            <tr class="border-b border-ink/5 hover:bg-ink/[0.02] transition-colors">
              <td class="py-2.5 pr-2 text-xs text-ink/40 font-mono align-middle">{k.id}</td>
              <td class="py-2.5 px-2 align-middle">
                <span class="text-2xl font-jp font-bold text-ink">{k.kanji}</span>
              </td>
              <td class="py-2.5 px-2 text-sm text-ink/75 align-middle">{k.meanings.join(", ")}</td>
              <td class="py-2.5 px-2 text-sm text-ink/60 hidden sm:table-cell align-middle font-jp">{k.kun.map(r => r.replace(/\..+$/, "")).join("、") || "—"}</td>
              <td class="py-2.5 px-2 text-sm text-ink/60 hidden sm:table-cell align-middle font-jp">{k.on.join("、") || "—"}</td>
              <td class="py-2.5 pl-2 text-center align-middle">
                <input type="checkbox" class="check-cell w-4 h-4 accent-vermilion cursor-pointer" />
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</DefaultLayout>

<script>
  document.getElementById("print-btn")!.onclick = () => window.print()
</script>

<style is:global>
  @media print {
    body > header, body > footer, body > main > div > div.text-center > button,
    .skip-link, nav, aside, [id="share-bar"] {
      display: none !important;
    }
    body > main > div > div.text-center > h1 {
      font-size: 1.5rem !important;
      margin-bottom: 0.5rem !important;
    }
    body > main > div > div.text-center > p {
      margin-bottom: 0.5rem !important;
    }
    #checklist {
      animation: none !important;
    }
    table {
      font-size: 0.875rem !important;
    }
    .check-cell {
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }
    .hidden\:sm\:table-cell {
      display: table-cell !important;
    }
    @page {
      margin: 0.75in;
      size: letter portrait;
    }
  }
</style>
