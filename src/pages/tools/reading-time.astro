---
import DefaultLayout from "@/layouts/DefaultLayout.astro"
---

<DefaultLayout title="Japanese Reading Time Calculator" description="Estimate how long it takes to read Japanese text. Calculate reading speed for JLPT preparation." keywords="Japanese reading time, reading speed Japanese, JLPT reading time, how long to read Japanese, Japanese reading calculator, text reading time">
  <div class="max-w-3xl mx-auto px-4 py-8 sm:py-12">
    <div class="text-center mb-8 animate-fade-up">
      <h1 class="text-3xl sm:text-4xl font-black text-ink">Reading Time Calculator</h1>
      <p class="text-sm text-ink/60 mt-2">Estimate how long it takes to read Japanese text.</p>
    </div>
    <div class="card p-5 sm:p-6 animate-fade-up" style="animation-delay:80ms">
      <label class="text-xs font-bold uppercase tracking-widest text-ink/40 mb-2 block" for="rt-input">Paste Japanese text</label>
      <textarea id="rt-input" class="w-full h-28 sm:h-32 rounded-xl border border-ink/15 bg-white p-3.5 sm:p-4 text-base leading-relaxed resize-y focus:outline-none focus:ring-2 focus:ring-vermilion/40 focus:border-vermilion/60 transition-all" placeholder="Paste Japanese text here…"></textarea>
      <div class="flex flex-wrap gap-2 mt-3">
        <label class="text-xs text-ink/50 self-center">Your reading speed:</label>
        <button class="rt-speed on btn h-8 px-3 text-xs rounded-full" data-cpm="300">Beginner</button>
        <button class="rt-speed btn h-8 px-3 text-xs rounded-full" data-cpm="600">Intermediate</button>
        <button class="rt-speed btn h-8 px-3 text-xs rounded-full" data-cpm="1000">Advanced</button>
      </div>
    </div>
    <div class="grid grid-cols-3 gap-3 mt-4" id="rt-stats">
      {["Chars","Kanji","Time"].map(l=>`<div class="card p-4 text-center"><div class="text-2xl font-black text-ink" data-rt="${l.toLowerCase()}">0</div><div class="text-[11px] text-ink/50 mt-1 font-medium uppercase tracking-wider">${l}</div></div>`).join("")}
    </div>
  </div>
</DefaultLayout>

<script>
  const input=document.getElementById("rt-input") as HTMLTextAreaElement
  let cpm=300
  document.querySelectorAll(".rt-speed").forEach(b=>b.addEventListener("click",function(){
    document.querySelectorAll(".rt-speed").forEach(x=>x.classList.remove("on"))
    this.classList.add("on");cpm=parseInt((this as HTMLElement).dataset.cpm!);update()
  }))
  function update(){
    const t=input.value,chars=t.length
    const kanji=[...t].filter(c=>{const p=c.codePointAt(0)!;return p>=0x4e00&&p<=0x9fff}).length
    const min=chars/cpm,sec=Math.round((min-Math.floor(min))*60)
    document.querySelector("[data-rt=chars]")!.textContent=chars.toLocaleString()
    document.querySelector("[data-rt=kanji]")!.textContent=kanji.toLocaleString()
    document.querySelector("[data-rt=time]")!.textContent=`${Math.floor(min)}m ${sec}s`
  }
  input.addEventListener("input",update)
</script>
