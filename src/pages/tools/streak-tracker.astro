---
import DefaultLayout from "@/layouts/DefaultLayout.astro"
---

<DefaultLayout title="Study Streak Tracker" description="Track your daily Japanese study streak. Mark days you studied and build a winning streak." keywords="Japanese study streak, study tracker, daily study log, streak counter, language learning habit, study calendar Japanese">
  <div class="max-w-3xl mx-auto px-4 py-8 sm:py-12">
    <div class="text-center mb-8 animate-fade-up">
      <h1 class="text-3xl sm:text-4xl font-black text-ink">Study Streak Tracker</h1>
      <p class="text-sm text-ink/60 mt-2">Mark each day you study and track your streak. Data stays on your device.</p>
    </div>
    <div class="card p-5 sm:p-6 animate-fade-up text-center" style="animation-delay:80ms">
      <div class="text-[11px] text-ink/40 font-medium uppercase tracking-wider">Current streak</div>
      <div id="streak-count" class="text-6xl sm:text-7xl font-black text-ink mt-1">0</div>
      <div class="text-xs text-ink/50 mt-1">days</div>
      <div class="flex justify-center gap-3 mt-5">
        <button id="streak-mark" class="btn btn-accent h-11 px-6 text-sm">✓ I studied today</button>
        <button id="streak-reset" class="btn btn-ghost h-11 px-5 text-sm">Reset</button>
      </div>
      <div id="streak-msg" class="text-xs text-ink/50 mt-3" hidden></div>
    </div>
    <div class="card p-5 sm:p-6 mt-4 animate-fade-up" style="animation-delay:120ms">
      <h2 class="text-xs font-bold uppercase tracking-widest text-ink/40 mb-3">Last 7 days</h2>
      <div id="streak-week" class="flex justify-center gap-2"></div>
    </div>
  </div>
</DefaultLayout>

<script>
  const KEY="kanjitest_streak"
  function load():string[]{try{return JSON.parse(localStorage.getItem(KEY)||"[]")}catch{return[]}}
  function save(d:string[]){localStorage.setItem(KEY,JSON.stringify(d))}
  function todayKey(){return new Date().toISOString().slice(0,10)}
  function calc(dates:string[]):number{
    let s=0;const today=new Date()
    for(let i=0;i<365;i++){
      const d=new Date(today);d.setDate(d.getDate()-i)
      const k=d.toISOString().slice(0,10)
      if(dates.includes(k))s++;else break
    }
    return s
  }
  const dates=load(),strk=document.getElementById("streak-count")!
  const week=document.getElementById("streak-week")!,msg=document.getElementById("streak-msg")!
  function render(){
    const s=calc(dates);strk.textContent=String(s)
    const today=todayKey()
    week.innerHTML="";for(let i=6;i>=0;i--){
      const d=new Date();d.setDate(d.getDate()-i)
      const k=d.toISOString().slice(0,10)
      const el=document.createElement("div")
      el.className="w-9 h-9 rounded-lg flex items-center justify-center text-xs font-bold "+
        (dates.includes(k)?"bg-vermilion text-white":"bg-ink/5 text-ink/40")
      el.textContent=String(d.getDate())
      week.appendChild(el)
    }
    msg.hidden=false
    msg.textContent=dates.includes(today)?"Already marked today! Keep going \u{1F389}":"Don't forget to study today!"
  }
  document.getElementById("streak-mark")!.onclick=()=>{
    const k=todayKey()
    if(!dates.includes(k)){dates.push(k);save(dates)}
    render()
  }
  document.getElementById("streak-reset")!.onclick=()=>{localStorage.removeItem(KEY);dates.length=0;render()}
  render()
</script>
