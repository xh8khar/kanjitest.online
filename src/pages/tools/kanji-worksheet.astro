---
import DefaultLayout from "@/layouts/DefaultLayout.astro"
import ButtonGroup from "@/components/tools/ButtonGroup.astro"
---

<DefaultLayout
  title="Kanji Worksheet Generator — Custom Practice Sheets"
  description="Generate custom kanji practice worksheets. Choose JLPT level and number of kanji to create printable writing practice sheets."
  keywords="kanji worksheet, kanji practice sheet, JLPT kanji writing practice, printable kanji worksheet, kanji handwriting practice, Japanese writing practice, free kanji worksheet generator"
>
  <div class="max-w-4xl mx-auto px-4 py-8 sm:py-12">
    <div class="text-center mb-8 animate-fade-up">
      <h1 class="text-3xl sm:text-4xl font-black text-ink">Kanji Worksheet Generator</h1>
      <p class="text-sm text-ink/60 mt-2">Create custom kanji writing practice sheets. Pick a level and how many kanji to practice.</p>
    </div>

    <div class="card p-5 sm:p-6 animate-fade-up text-center" style="animation-delay:80ms">
      <div class="mb-4">
        <p class="text-[11px] font-bold uppercase tracking-widest text-ink/40 mb-2">JLPT Level</p>
        <ButtonGroup classPrefix="ws-lvl" buttons={["N5","N4","N3","N2","N1"]} />
      </div>

      <div class="mb-5">
        <p class="text-[11px] font-bold uppercase tracking-widest text-ink/40 mb-2">Number of Kanji</p>
        <div class="flex justify-center gap-2">
          {[5, 10, 15, 20].map((n) => (
            <button class:list={["ws-count", "btn", "h-8", "px-3.5", "text-xs", "rounded-full", { on: n === 10 }]} data-count={n}>{n}</button>
          ))}
        </div>
      </div>

      <div class="flex justify-center gap-2">
        <button id="ws-generate" class="btn btn-accent h-10 px-5 text-sm">Generate Worksheet</button>
        <button id="ws-print" class="btn btn-ghost h-10 px-5 text-sm" disabled>Print / Save PDF</button>
      </div>
    </div>

    <div id="ws-output" class="mt-6" hidden>
      <div id="ws-cards" class="grid grid-cols-1 sm:grid-cols-2 gap-4"></div>
    </div>
  </div>
</DefaultLayout>

<script>
  type Entry = { kanji: string; meanings: string[]; level: string; strokes: number; kun: string[]; on: string[] }
  let data: Entry[] = [], activeLvl = "n5"

  const cardsEl = document.getElementById("ws-cards")!
  const outputEl = document.getElementById("ws-output")!
  const printBtn = document.getElementById("ws-print") as HTMLButtonElement

  fetch("/api/kanji.json").then(r => r.json()).then(d => { data = d })

  function getActiveCount(): number {
    const active = document.querySelector(".ws-count.on")
    return active ? parseInt((active as HTMLElement).dataset.count!) : 10
  }

  document.getElementById("ws-generate")!.onclick = () => {
    const pool = data.filter(e => e.level === activeLvl).sort(() => Math.random() - 0.5).slice(0, getActiveCount())
    if (!pool.length) return
    cardsEl.innerHTML = pool.map(e => `
      <div class="ws-card rounded-xl border border-ink/15 bg-white p-5 text-center print:border-ink/30 print:break-inside-avoid">
        <div class="text-6xl sm:text-7xl font-jp font-black text-ink leading-none mb-2">${e.kanji}</div>
        <div class="text-[11px] text-ink/40 uppercase tracking-wider mb-2">${e.level.toUpperCase()} · ${e.strokes} strokes</div>
        <div class="text-xs text-ink/60 font-jp mb-1">${[...e.on, ...e.kun].filter(Boolean).join("、") || "—"}</div>
        <div class="text-xs text-ink/75 mb-4">${e.meanings.join(", ")}</div>
        <div class="grid grid-cols-3 gap-2">
          ${Array.from({ length: 3 }, () => `
            <div class="aspect-square rounded-lg border-2 border-dashed border-ink/15 bg-ink/[0.02]"></div>
          `).join("")}
        </div>
      </div>
    `).join("")
    outputEl.hidden = false
    printBtn.disabled = false
  }

  printBtn.onclick = () => window.print()

  document.querySelectorAll(".ws-lvl").forEach(b => b.addEventListener("click", function() {
    document.querySelectorAll(".ws-lvl").forEach(x => x.classList.remove("on"))
    this.classList.add("on")
    activeLvl = (this as HTMLElement).dataset.lvl!
  }))

  document.querySelectorAll(".ws-count").forEach(b => b.addEventListener("click", function() {
    document.querySelectorAll(".ws-count").forEach(x => x.classList.remove("on"))
    this.classList.add("on")
  }))
</script>

<style is:global>
  @media print {
    body > *:not(#ws-cards, #ws-cards *) { display: none !important; }
    #ws-cards { max-width: 100% !important; }
    #ws-cards { grid-template-columns: repeat(2, 1fr) !important; }
    .ws-card { box-shadow: none !important; border: 1px solid #ccc !important; page-break-inside: avoid !important; }
    @page { margin: 0.5in; }
  }
</style>
