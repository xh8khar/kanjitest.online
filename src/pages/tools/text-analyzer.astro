---
import DefaultLayout from "@/layouts/DefaultLayout.astro"
---

<DefaultLayout title="Japanese Text Analyzer — Character Counter" description="Free online Japanese text analyzer. Count kanji, hiragana, katakana, romaji, and punctuation characters in any text." keywords="Japanese text analyzer, character counter, kanji counter, hiragana counter, Japanese text analysis, count Japanese characters">
  <div class="max-w-3xl mx-auto px-4 py-8 sm:py-12">
    <div class="text-center mb-8 animate-fade-up">
      <h1 class="text-3xl sm:text-4xl font-black text-ink">Japanese Text Analyzer</h1>
      <p class="text-sm text-ink/60 mt-2">Paste any text and see a detailed character breakdown.</p>
    </div>

    <div class="card p-5 sm:p-6 animate-fade-up" style="animation-delay: 80ms">
      <label class="text-xs font-bold uppercase tracking-widest text-ink/40 mb-2 block" for="text-input">Enter Japanese text</label>
      <textarea id="text-input" class="w-full h-28 sm:h-32 rounded-xl border border-ink/15 bg-white p-3.5 sm:p-4 text-base leading-relaxed resize-y focus:outline-none focus:ring-2 focus:ring-vermilion/40 focus:border-vermilion/60 transition-all" placeholder="Paste or type Japanese text here…"></textarea>
    </div>

    <div id="stats" class="grid grid-cols-2 sm:grid-cols-3 gap-3 mt-4">
      {["Total", "Kanji", "Hiragana", "Katakana", "Romaji / Other", "Spaces"].map((label) => (
        <div class="card p-4 text-center animate-fade-up stat-card" data-stat={label.toLowerCase().replace(/[^a-z]/g, "")}>
          <div class="text-2xl sm:text-3xl font-black text-ink stat-value">0</div>
          <div class="text-[11px] text-ink/50 mt-1 font-medium uppercase tracking-wider">{label}</div>
        </div>
      ))}
    </div>
  </div>
</DefaultLayout>

<script>
  const input = document.getElementById("text-input") as HTMLTextAreaElement

  function analyze(text: string) {
    let kanji = 0, hira = 0, kata = 0, other = 0, spaces = 0
    for (const ch of text) {
      const cp = ch.codePointAt(0)!
      if (ch === " " || ch === "\n" || ch === "\t") { spaces++; continue }
      if (cp >= 0x4e00 && cp <= 0x9fff) { kanji++; continue }
      if (cp >= 0x3041 && cp <= 0x3096) { hira++; continue }
      if (cp >= 0x30a1 && cp <= 0x30fa) { kata++; continue }
      other++
    }
    return { total: text.length, kanji, hira, kata, other, spaces }
  }

  function update() {
    const s = analyze(input.value)
    const map: Record<string, number> = {
      total: s.total, kanji: s.kanji, hiragana: s.hira, katakana: s.kata,
      romajiother: s.other, spaces: s.spaces,
    }
    document.querySelectorAll(".stat-card").forEach((el) => {
      const key = (el as HTMLElement).dataset.stat!
      const val = map[key] ?? 0
      el.querySelector(".stat-value")!.textContent = val.toLocaleString()
    })
  }

  input.addEventListener("input", update)
  update()
</script>
