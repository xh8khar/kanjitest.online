---
import BaseLayout from "@/layouts/BaseLayout.astro"
import LevelLayout from "@/layouts/LevelLayout.astro"
import { getByKanji, getPrevNext, getAll, getSetForKanji } from "@/lib/kanji"
import { siteUrl, breadcrumbSchema, definedTermSchema } from "@/lib/seo"

export async function getStaticPaths() {
  const all = getAll()
  return all.map((k) => ({ params: { kanji: k.kanji } }))
}

const { kanji } = Astro.params
const decoded = decodeURIComponent(kanji!)
const k = getByKanji(decoded)

if (!k) {
  return Astro.redirect("/404")
}

const { prev, next } = getPrevNext(k.id)
const setNum = getSetForKanji(k.id)
const ex = k.examples.slice(0, 3)

const termSchema = definedTermSchema(k.kanji, k.meanings.join(", "), k.id)
const breadSchema = breadcrumbSchema([
  { name: "Home", url: "/" },
  { name: "N5", url: "/n5/" },
  { name: "Study", url: "/n5/study/" },
  { name: k.kanji, url: `/n5/study/${k.kanji}/` },
])

const desc = `Learn the JLPT N5 kanji ${k.kanji} (${k.meanings[0]}). Example: ${ex[0]?.word} (${ex[0]?.reading}) — ${ex[0]?.english}.`
---

<BaseLayout
  title={`${k.kanji} (${k.meanings[0]}) — JLPT N5 Kanji`}
  description={desc}
>
  <LevelLayout level="n5">
    <script type="application/ld+json" set:html={JSON.stringify(breadSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(termSchema)} />

    <div class="px-4 py-6 sm:py-8">
      <nav class="text-[11px] sm:text-xs text-ink/50 mb-3 sm:mb-4 flex flex-wrap items-center gap-0.5">
        <a href="/" class="text-ink/50 hover:text-ink transition-colors px-1.5 sm:px-2 py-1.5">Home</a>
        <span>/</span>
        <a href="/n5/" class="text-ink/50 hover:text-ink transition-colors px-1.5 sm:px-2 py-1.5">N5</a>
        <span>/</span>
        <a href="/n5/study/" class="text-ink/50 hover:text-ink transition-colors px-1.5 sm:px-2 py-1.5">Study</a>
        <span>/</span>
        <span class="text-ink/70 px-1.5 sm:px-2 py-1">{k.kanji}</span>
      </nav>

      <div class="border border-ink/20 rounded-xl bg-white mb-4 sm:mb-5">
        <div class="text-5xl sm:text-6xl text-center py-6 sm:py-8 font-black text-ink">
          {k.kanji}
        </div>
        {k.strokes > 0 && (
          <p class="text-xs text-ink/50 text-center -mt-2 sm:-mt-3 pb-1 sm:pb-2">{k.strokes} strokes</p>
        )}
        <div class="px-4 sm:px-5 pb-3 sm:pb-4 flex flex-wrap justify-center gap-1 sm:gap-1.5">
          {k.meanings.map((m) => (
            <span class="inline-flex items-center px-2.5 sm:px-3 py-0.5 sm:py-1 rounded-md bg-ink/10 text-xs text-ink/70">{m}</span>
          ))}
        </div>

        <div class="px-4 sm:px-5 pb-4 sm:pb-5 grid grid-cols-2 gap-2">
          {k.kun.length > 0 && (
            <div class="border border-ink/20 rounded-lg px-3 sm:px-4 py-2.5 sm:py-3">
              <p class="text-[11px] sm:text-xs text-ink/50 uppercase mb-0.5 sm:mb-1">kun</p>
              <p class="text-sm text-ink">{k.kun.map((r) => r.replace(/\..+$/, "")).join("、")}</p>
            </div>
          )}
          {k.on.length > 0 && (
            <div class="border border-ink/20 rounded-lg px-3 sm:px-4 py-2.5 sm:py-3">
              <p class="text-[11px] sm:text-xs text-ink/50 uppercase mb-0.5 sm:mb-1">on</p>
              <p class="text-sm text-ink">{k.on.join("、")}</p>
            </div>
          )}
        </div>
      </div>

      <div class="mb-5 sm:mb-6">
        <div class="border-t border-ink/20 my-5 sm:my-6" />
        <p class="text-[11px] sm:text-xs font-medium uppercase tracking-widest text-ink/50 mb-3 sm:mb-4">Example Words</p>
        <div class="space-y-1.5 sm:space-y-2">
          {ex.map((e, i) => (
            <div key={i} class="border border-ink/20 rounded-xl px-4 sm:px-5 py-3 sm:py-4 bg-white">
              <p class="text-sm sm:text-base font-bold text-ink">{e.word}</p>
              <p class="text-[11px] sm:text-xs text-ink/70 mt-0.5">{e.reading}</p>
              {e.sentence && (
                <p class="text-xs sm:text-sm text-ink/70 mt-1.5 sm:mt-2">{e.sentence}</p>
              )}
              <p class="text-[11px] sm:text-xs text-ink/60 mt-1">{e.sentenceEnglish || e.english}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="flex flex-wrap gap-2 mb-5 sm:mb-6">
        <a href="/n5/flashcards/" class="border border-ink/20 rounded-lg h-10 sm:h-11 px-4 sm:px-5 text-xs sm:text-sm text-ink/70 hover:border-ink/40 hover:text-ink transition-all flex items-center gap-1">
          🃏 Flashcards
        </a>
        <a href={`/n5/sets/${setNum}/`} class="border border-ink/20 rounded-lg h-10 sm:h-11 px-4 sm:px-5 text-xs sm:text-sm text-ink/70 hover:border-ink/40 hover:text-ink transition-all flex items-center gap-1">
          ✍️ Test (Set {setNum})
        </a>
      </div>

      <div class="flex gap-2">
        {prev ? (
          <a href={`/n5/study/${prev.kanji}/`} class="flex-1 border border-ink/20 rounded-lg h-12 flex items-center gap-1.5 sm:gap-2 px-3 sm:px-4 text-xs sm:text-sm text-ink/70 hover:border-ink/40 hover:text-ink transition-all">
            <span>&larr;</span>
            <span>{prev.kanji}</span>
            <span class="hidden sm:inline text-ink/50 text-[11px]">#{prev.id}</span>
          </a>
        ) : <div class="flex-1" />}
        {next ? (
          <a href={`/n5/study/${next.kanji}/`} class="flex-1 border border-ink/20 rounded-lg h-12 flex items-center gap-1.5 sm:gap-2 px-3 sm:px-4 justify-end text-xs sm:text-sm text-ink/70 hover:border-ink/40 hover:text-ink transition-all">
            <span class="hidden sm:inline text-ink/50 text-[11px]">#{next.id}</span>
            <span>{next.kanji}</span>
            <span>&rarr;</span>
          </a>
        ) : <div class="flex-1" />}
      </div>
    </div>
  </LevelLayout>
</BaseLayout>
