---
import BaseLayout from "@/layouts/BaseLayout.astro"
import LevelLayout from "@/layouts/LevelLayout.astro"
import FlashcardsClient from "@/components/FlashcardsClient"
import { getAll, getByKanji } from "@/lib/kanji"

export async function getStaticPaths() {
  const all = getAll()
  return all.map((k) => ({ params: { kanji: k.kanji } }))
}

const level = "n5"
const { kanji } = Astro.params
const decoded = decodeURIComponent(kanji!)
const k = getByKanji(decoded)

if (!k) {
  return Astro.redirect(`/${level}/flashcards/`)
}

const title = `Flashcard: ${k.kanji} (${k.meanings[0]}) — JLPT N5`
const description = `Flashcard for JLPT N5 kanji ${k.kanji} (${k.meanings[0]}). Flip to see readings, meanings, and example words.`
---

<BaseLayout {title} {description}>
  <LevelLayout level={level}>
    <FlashcardsClient kanji={decoded} level={level} client:load />
  </LevelLayout>
</BaseLayout>
