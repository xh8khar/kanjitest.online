---
import FlashcardPage from "@/components/level/FlashcardPage.astro"
import { getAll } from "@/lib/kanji"

export function getStaticPaths() {
  return getAll("n5").map((k) => ({ params: { kanji: k.kanji } }))
}

const kanji = decodeURIComponent(Astro.params.kanji!)
---

<FlashcardPage level="n5" kanji={kanji} />
