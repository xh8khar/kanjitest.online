---
import BaseLayout from "@/layouts/BaseLayout.astro"
import LevelLayout from "@/layouts/LevelLayout.astro"
import TestClient from "@/components/TestClient"
import { siteUrl } from "@/lib/seo"

export async function getStaticPaths() {
  return Array.from({ length: 20 }, (_, i) => ({ params: { set: String(i + 1) } }))
}

const level = "n5"
const { set } = Astro.params
const setNum = parseInt(set!, 10)
const title = `Kanji Test Online – JLPT N5 Kanji Quiz Set ${setNum} (20 Questions)`
const description = `Practice JLPT N5 kanji with Set ${setNum} of 20 questions. Test your kanji-to-reading and reading-to-kanji skills with real sentence context.`
---

<BaseLayout {title} {description}>
  <LevelLayout level={level}>
    <TestClient setNum={setNum} level={level} client:load />
  </LevelLayout>
</BaseLayout>
