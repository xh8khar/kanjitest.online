---
import BaseLayout from "@/layouts/BaseLayout.astro"
import LevelLayout from "@/layouts/LevelLayout.astro"
import { siteUrl, collectionPageSchema, keywords as kw } from "@/lib/seo"

const pageSchema = collectionPageSchema("JLPT N5 Kanji Tests — 20 Practice Quizzes", "20 test sets of 20 questions each for JLPT N5 kanji.", "/n5/sets")
---

<BaseLayout
  title="JLPT N5 Kanji Tests — 20 Practice Quizzes"
  description="20 test sets of 20 questions each. Practice reading and meaning recognition for JLPT N5 kanji with real sentence context."
>
  <LevelLayout level="n5">
    <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

    <div class="px-4 py-6 sm:py-8">
      <h1 class="text-lg sm:text-xl font-bold text-ink">Tests</h1>
      <p class="text-xs text-ink/60 mt-1 mb-5 sm:mb-6">20 sets &middot; 20 questions each</p>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2">
        {Array.from({ length: 20 }, (_, i) => i + 1).map((n) => (
          <a
            key={n}
            href={`/n5/sets/${n}/`}
            class="border border-ink/20 rounded-xl py-4 sm:py-5 text-center bg-white hover:border-ink/40 transition-all"
          >
            <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-lg bg-ink/10 flex items-center justify-center mx-auto mb-1.5 sm:mb-2">
              <span class="text-xs sm:text-sm font-medium text-ink/70">{n}</span>
            </div>
            <p class="text-xs sm:text-sm text-ink">Set {n}</p>
            <p class="text-[10px] sm:text-xs text-ink/60 mt-0.5">20 questions</p>
          </a>
        ))}
      </div>
    </div>
  </LevelLayout>
</BaseLayout>
